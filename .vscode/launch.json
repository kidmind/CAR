{
    "configurations": [
    {
        "executable": "./build/CAR.elf",
        "name": "Debug with OpenOCD",
        "cwd":"${workspaceFolder}",        
        "request": "launch",
        "type": "cortex-debug",
        "servertype": "openocd",
        "configFiles": [
            "interface/cmsis-dap.cfg",
            "target/stm32f4x.cfg"
        ],
        "searchDir": [],
        "device":"STM32F407ZGT6",
        "interface": "swd",
        "runToEntryPoint": "main",
        "showDevDebugOutput": "raw",
        "svdFile": "${workspaceFolder}/STM32F407.svd",
        "gdbPath": "gdb-multiarch",
        "liveWatch": {
            "enabled": true,
            "samplesPerSecond": 10
        }
    }]
}
