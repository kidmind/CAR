 403:MyHardWare/Src/lcd.c **** /******************************************************************************
 404:MyHardWare/Src/lcd.c ****       函数说明：显示汉字串
 405:MyHardWare/Src/lcd.c ****       入口数据：x,y显示坐标
 406:MyHardWare/Src/lcd.c ****                 *s 要显示的汉字串
 407:MyHardWare/Src/lcd.c ****                 fc 字的颜色
 408:MyHardWare/Src/lcd.c ****                 bc 字的背景色
 409:MyHardWare/Src/lcd.c ****                 sizey 字号 可选 16 24 32
 410:MyHardWare/Src/lcd.c ****                 mode:  0非叠加模式  1叠加模式
 411:MyHardWare/Src/lcd.c ****       返回值  ：无
 412:MyHardWare/Src/lcd.c **** ******************************************************************************/
 413:MyHardWare/Src/lcd.c **** void LCD_ShowChinese(u16 x,u16 y,u8 *s,u16 fc,u16 bc,u8 sizey,u8 mode)
 414:MyHardWare/Src/lcd.c **** {
 415:MyHardWare/Src/lcd.c **** 	while(*s!=0)
 416:MyHardWare/Src/lcd.c **** 	{
 417:MyHardWare/Src/lcd.c **** 		if(sizey==12) LCD_ShowChinese12x12(x,y,s,fc,bc,sizey,mode);
 418:MyHardWare/Src/lcd.c **** 		else if(sizey==16) LCD_ShowChinese16x16(x,y,s,fc,bc,sizey,mode);
