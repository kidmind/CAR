 420:MyHardWare/Src/lcd.c **** 		else if(sizey==32) LCD_ShowChinese32x32(x,y,s,fc,bc,sizey,mode);
 421:MyHardWare/Src/lcd.c **** 		else return;
 422:MyHardWare/Src/lcd.c **** 		s+=2;
 423:MyHardWare/Src/lcd.c **** 		x+=sizey;
 424:MyHardWare/Src/lcd.c **** 	}
 425:MyHardWare/Src/lcd.c **** }
