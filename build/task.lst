1521:CMSIS/core_cm4.h ****   reg_value &= ~((uint32_t)(SCB_AIRCR_VECTKEY_Msk | SCB_AIRCR_PRIGROUP_Msk));             /* clear 
1522:CMSIS/core_cm4.h ****   reg_value  =  (reg_value                                   |
1523:CMSIS/core_cm4.h ****                 ((uint32_t)0x5FAUL << SCB_AIRCR_VECTKEY_Pos) |
1524:CMSIS/core_cm4.h ****                 (PriorityGroupTmp << 8)                       );              /* Insert write key a
1525:CMSIS/core_cm4.h ****   SCB->AIRCR =  reg_value;
1526:CMSIS/core_cm4.h **** }
1527:CMSIS/core_cm4.h **** 
1528:CMSIS/core_cm4.h **** 
1529:CMSIS/core_cm4.h **** /** \brief  Get Priority Grouping
1530:CMSIS/core_cm4.h **** 
1531:CMSIS/core_cm4.h ****   The function reads the priority grouping field from the NVIC Interrupt Controller.
1532:CMSIS/core_cm4.h **** 
