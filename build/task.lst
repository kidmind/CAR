1727:CMSIS/core_cm4.h ****                             SCB_AIRCR_SYSRESETREQ_Msk    );         /* Keep priority group unchange
1728:CMSIS/core_cm4.h ****   __DSB();                                                          /* Ensure completion of memory 
1729:CMSIS/core_cm4.h ****   while(1) { __NOP(); }                                             /* wait until reset */
1730:CMSIS/core_cm4.h **** }
