1721:CMSIS/core_cm4.h **** __STATIC_INLINE void NVIC_SystemReset(void)
1722:CMSIS/core_cm4.h **** {
1723:CMSIS/core_cm4.h ****   __DSB();                                                          /* Ensure all outstanding memor
1724:CMSIS/core_cm4.h ****                                                                        buffered write are completed
1725:CMSIS/core_cm4.h ****   SCB->AIRCR  = (uint32_t)((0x5FAUL << SCB_AIRCR_VECTKEY_Pos)    |
