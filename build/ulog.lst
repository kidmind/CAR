  61:MyHardWare/Src/ulog.c **** void ulog_init() {
  62:MyHardWare/Src/ulog.c ****   memset(s_subscribers, 0, sizeof(s_subscribers));
  63:MyHardWare/Src/ulog.c ****   s_lowest_log_level = ulog_lowest_log_level();
  64:MyHardWare/Src/ulog.c **** }
  65:MyHardWare/Src/ulog.c **** 
  66:MyHardWare/Src/ulog.c **** // search the s_subscribers table to install or update fn
  67:MyHardWare/Src/ulog.c **** ulog_err_t ulog_subscribe(ulog_function_t fn, ulog_level_t threshold) {
  68:MyHardWare/Src/ulog.c ****   int available_slot = -1;
  69:MyHardWare/Src/ulog.c ****   int i;
  70:MyHardWare/Src/ulog.c ****   for (i=0; i<ULOG_MAX_SUBSCRIBERS; i++) {
  71:MyHardWare/Src/ulog.c ****     if (s_subscribers[i].fn == fn) {
  72:MyHardWare/Src/ulog.c ****       // already subscribed: update threshold and return immediately.
  73:MyHardWare/Src/ulog.c ****       s_subscribers[i].threshold = threshold;
  74:MyHardWare/Src/ulog.c ****       return ULOG_ERR_NONE;
  75:MyHardWare/Src/ulog.c **** 
  76:MyHardWare/Src/ulog.c ****     } else if (s_subscribers[i].fn == NULL) {
  77:MyHardWare/Src/ulog.c ****       // found a free slot
  78:MyHardWare/Src/ulog.c ****       available_slot = i;
  79:MyHardWare/Src/ulog.c ****     }
  80:MyHardWare/Src/ulog.c ****   }
  81:MyHardWare/Src/ulog.c ****   // fn is not yet a subscriber.  assign if possible.
  82:MyHardWare/Src/ulog.c ****   if (available_slot == -1) {
  83:MyHardWare/Src/ulog.c ****     return ULOG_ERR_SUBSCRIBERS_EXCEEDED;
  84:MyHardWare/Src/ulog.c ****   }
  85:MyHardWare/Src/ulog.c ****   s_subscribers[available_slot].fn = fn;
  86:MyHardWare/Src/ulog.c ****   s_subscribers[available_slot].threshold = threshold;
  87:MyHardWare/Src/ulog.c ****   s_lowest_log_level = ulog_lowest_log_level(); // Update lowest log level
  88:MyHardWare/Src/ulog.c **** 
ARM GAS  C:\Users\asus\AppData\Local\Temp\ccPSL3d3.s 			page 3


  89:MyHardWare/Src/ulog.c ****   return ULOG_ERR_NONE;
  90:MyHardWare/Src/ulog.c **** }
  91:MyHardWare/Src/ulog.c **** 
  92:MyHardWare/Src/ulog.c **** // search the s_subscribers table to remove
  93:MyHardWare/Src/ulog.c **** ulog_err_t ulog_unsubscribe(ulog_function_t fn) {
  94:MyHardWare/Src/ulog.c ****   int i;
  95:MyHardWare/Src/ulog.c ****   for (i=0; i<ULOG_MAX_SUBSCRIBERS; i++) {
  96:MyHardWare/Src/ulog.c ****     if (s_subscribers[i].fn == fn) {
  97:MyHardWare/Src/ulog.c ****       s_subscribers[i].fn = NULL;    // mark as empty
  98:MyHardWare/Src/ulog.c ****       s_lowest_log_level = ulog_lowest_log_level(); // Update lowest log level
  99:MyHardWare/Src/ulog.c ****       return ULOG_ERR_NONE;
 100:MyHardWare/Src/ulog.c ****     }
 101:MyHardWare/Src/ulog.c ****   }
 102:MyHardWare/Src/ulog.c ****   return ULOG_ERR_NOT_SUBSCRIBED;
 103:MyHardWare/Src/ulog.c **** }
 104:MyHardWare/Src/ulog.c **** 
 105:MyHardWare/Src/ulog.c **** const char *ulog_level_name(ulog_level_t severity) {
 106:MyHardWare/Src/ulog.c ****   switch(severity) {
 107:MyHardWare/Src/ulog.c ****    case ULOG_TRACE_LEVEL: return "TRACE";
 108:MyHardWare/Src/ulog.c ****    case ULOG_DEBUG_LEVEL: return "DEBUG";
 109:MyHardWare/Src/ulog.c ****    case ULOG_INFO_LEVEL: return "INFO";
 110:MyHardWare/Src/ulog.c ****    case ULOG_WARNING_LEVEL: return "WARNING";
 111:MyHardWare/Src/ulog.c ****    case ULOG_ERROR_LEVEL: return "ERROR";
 112:MyHardWare/Src/ulog.c ****    case ULOG_CRITICAL_LEVEL: return "CRITICAL";
 113:MyHardWare/Src/ulog.c ****    case ULOG_ALWAYS_LEVEL: return "ALWAYS";
 114:MyHardWare/Src/ulog.c ****    default: return "UNKNOWN";
 115:MyHardWare/Src/ulog.c ****   }
 116:MyHardWare/Src/ulog.c **** }
 117:MyHardWare/Src/ulog.c **** 
 118:MyHardWare/Src/ulog.c **** void ulog_message(ulog_level_t severity, const char *fmt, ...) {
 119:MyHardWare/Src/ulog.c ****   // Do not evaluate the log message if it will never be logged
 120:MyHardWare/Src/ulog.c ****   if (severity < s_lowest_log_level){
 121:MyHardWare/Src/ulog.c ****     return;
 122:MyHardWare/Src/ulog.c ****   }
 123:MyHardWare/Src/ulog.c **** 
 124:MyHardWare/Src/ulog.c ****   va_list ap;
 125:MyHardWare/Src/ulog.c ****   int i;
 126:MyHardWare/Src/ulog.c ****   va_start(ap, fmt);
 127:MyHardWare/Src/ulog.c ****   vsnprintf(s_message, ULOG_MAX_MESSAGE_LENGTH, fmt, ap);
 128:MyHardWare/Src/ulog.c ****   va_end(ap);
 129:MyHardWare/Src/ulog.c **** 
 130:MyHardWare/Src/ulog.c ****   for (i=0; i<ULOG_MAX_SUBSCRIBERS; i++) {
 131:MyHardWare/Src/ulog.c ****     if (s_subscribers[i].fn != NULL) {
 132:MyHardWare/Src/ulog.c ****       if (severity >= s_subscribers[i].threshold) {
 133:MyHardWare/Src/ulog.c ****         s_subscribers[i].fn(severity, s_message);
 134:MyHardWare/Src/ulog.c ****       }
 135:MyHardWare/Src/ulog.c ****     }
 136:MyHardWare/Src/ulog.c ****   }
 137:MyHardWare/Src/ulog.c **** }
