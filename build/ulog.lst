  54:MyHardWare/Src/ulog.c **** static subscriber_t s_subscribers[ULOG_MAX_SUBSCRIBERS];
  55:MyHardWare/Src/ulog.c **** static char s_message[ULOG_MAX_MESSAGE_LENGTH];
  56:MyHardWare/Src/ulog.c **** static ulog_level_t s_lowest_log_level;
