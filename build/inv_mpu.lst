2908:MyHardWare/eMPL/inv_mpu.c ****     /*
2909:MyHardWare/eMPL/inv_mpu.c ****        XYZ  010_001_000 Identity Matrix
2910:MyHardWare/eMPL/inv_mpu.c ****        XZY  001_010_000
2911:MyHardWare/eMPL/inv_mpu.c ****        YXZ  010_000_001
2912:MyHardWare/eMPL/inv_mpu.c ****        YZX  000_010_001
2913:MyHardWare/eMPL/inv_mpu.c ****        ZXY  001_000_010
2914:MyHardWare/eMPL/inv_mpu.c ****        ZYX  000_001_010
2915:MyHardWare/eMPL/inv_mpu.c ****      */
2916:MyHardWare/eMPL/inv_mpu.c **** 
2917:MyHardWare/eMPL/inv_mpu.c ****     scalar = inv_row_2_scale(mtx);
2918:MyHardWare/eMPL/inv_mpu.c ****     scalar |= inv_row_2_scale(mtx + 3) << 3;
2919:MyHardWare/eMPL/inv_mpu.c ****     scalar |= inv_row_2_scale(mtx + 6) << 6;
2920:MyHardWare/eMPL/inv_mpu.c **** 
2921:MyHardWare/eMPL/inv_mpu.c **** 
2922:MyHardWare/eMPL/inv_mpu.c ****     return scalar;
2923:MyHardWare/eMPL/inv_mpu.c **** }
