1879:MyHardWare/eMPL/inv_mpu.c ****  *  @brief      Enable latched interrupts.
1880:MyHardWare/eMPL/inv_mpu.c ****  *  Any MPU register will clear the interrupt.
1881:MyHardWare/eMPL/inv_mpu.c ****  *  @param[in]  enable  1 to enable, 0 to disable.
1882:MyHardWare/eMPL/inv_mpu.c ****  *  @return     0 if successful.
1883:MyHardWare/eMPL/inv_mpu.c ****  */
1884:MyHardWare/eMPL/inv_mpu.c **** int mpu_set_int_latched(unsigned char enable)
1885:MyHardWare/eMPL/inv_mpu.c **** {
1886:MyHardWare/eMPL/inv_mpu.c ****     unsigned char tmp;
1887:MyHardWare/eMPL/inv_mpu.c ****     if (st.chip_cfg.latched_int == enable)
1888:MyHardWare/eMPL/inv_mpu.c ****         return 0;
1889:MyHardWare/eMPL/inv_mpu.c **** 
1890:MyHardWare/eMPL/inv_mpu.c ****     if (enable)
1891:MyHardWare/eMPL/inv_mpu.c ****         tmp = BIT_LATCH_EN | BIT_ANY_RD_CLR;
1892:MyHardWare/eMPL/inv_mpu.c ****     else
1893:MyHardWare/eMPL/inv_mpu.c ****         tmp = 0;
1894:MyHardWare/eMPL/inv_mpu.c ****     if (st.chip_cfg.bypass_mode)
1895:MyHardWare/eMPL/inv_mpu.c ****         tmp |= BIT_BYPASS_EN;
1896:MyHardWare/eMPL/inv_mpu.c ****     if (st.chip_cfg.active_low_int)
1897:MyHardWare/eMPL/inv_mpu.c ****         tmp |= BIT_ACTL;
1898:MyHardWare/eMPL/inv_mpu.c ****     if (i2c_write(st.hw->addr, st.reg->int_pin_cfg, 1, &tmp))
1899:MyHardWare/eMPL/inv_mpu.c ****         return -1;
1900:MyHardWare/eMPL/inv_mpu.c ****     st.chip_cfg.latched_int = enable;
1901:MyHardWare/eMPL/inv_mpu.c ****     return 0;
1902:MyHardWare/eMPL/inv_mpu.c **** }
