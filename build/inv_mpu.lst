2100:MyHardWare/eMPL/inv_mpu.c **** /**
2101:MyHardWare/eMPL/inv_mpu.c ****  *  @brief      Trigger gyro/accel/compass self-test.
2102:MyHardWare/eMPL/inv_mpu.c ****  *  On success/error, the self-test returns a mask representing the sensor(s)
2103:MyHardWare/eMPL/inv_mpu.c ****  *  that failed. For each bit, a one (1) represents a "pass" case; conversely,
2104:MyHardWare/eMPL/inv_mpu.c ****  *  a zero (0) indicates a failure.
2105:MyHardWare/eMPL/inv_mpu.c ****  *
2106:MyHardWare/eMPL/inv_mpu.c ****  *  \n The mask is defined as follows:
ARM GAS  C:\Users\asus\AppData\Local\Temp\ccirS3Oi.s 			page 171


2107:MyHardWare/eMPL/inv_mpu.c ****  *  \n Bit 0:   Gyro.
2108:MyHardWare/eMPL/inv_mpu.c ****  *  \n Bit 1:   Accel.
2109:MyHardWare/eMPL/inv_mpu.c ****  *  \n Bit 2:   Compass.
2110:MyHardWare/eMPL/inv_mpu.c ****  *
2111:MyHardWare/eMPL/inv_mpu.c ****  *  \n Currently, the hardware self-test is unsupported for MPU6500. However,
2112:MyHardWare/eMPL/inv_mpu.c ****  *  this function can still be used to obtain the accel and gyro biases.
2113:MyHardWare/eMPL/inv_mpu.c ****  *
2114:MyHardWare/eMPL/inv_mpu.c ****  *  \n This function must be called with the device either face-up or face-down
2115:MyHardWare/eMPL/inv_mpu.c ****  *  (z-axis is parallel to gravity).
2116:MyHardWare/eMPL/inv_mpu.c ****  *  @param[out] gyro        Gyro biases in q16 format.
2117:MyHardWare/eMPL/inv_mpu.c ****  *  @param[out] accel       Accel biases (if applicable) in q16 format.
2118:MyHardWare/eMPL/inv_mpu.c ****  *  @return     Result mask (see above).
2119:MyHardWare/eMPL/inv_mpu.c ****  */
2120:MyHardWare/eMPL/inv_mpu.c **** int mpu_run_self_test(long *gyro, long *accel) {
2121:MyHardWare/eMPL/inv_mpu.c **** #ifdef MPU6050
2122:MyHardWare/eMPL/inv_mpu.c ****   const unsigned char tries = 2;
2123:MyHardWare/eMPL/inv_mpu.c ****   long gyro_st[3], accel_st[3];
2124:MyHardWare/eMPL/inv_mpu.c ****   unsigned char accel_result, gyro_result;
2125:MyHardWare/eMPL/inv_mpu.c **** #ifdef AK89xx_SECONDARY
2126:MyHardWare/eMPL/inv_mpu.c ****   unsigned char compass_result;
2127:MyHardWare/eMPL/inv_mpu.c **** #endif
2128:MyHardWare/eMPL/inv_mpu.c ****   int ii;
2129:MyHardWare/eMPL/inv_mpu.c **** #endif
2130:MyHardWare/eMPL/inv_mpu.c ****   int result;
2131:MyHardWare/eMPL/inv_mpu.c ****   unsigned char accel_fsr, fifo_sensors, sensors_on;
2132:MyHardWare/eMPL/inv_mpu.c ****   unsigned short gyro_fsr, sample_rate, lpf;
2133:MyHardWare/eMPL/inv_mpu.c ****   unsigned char dmp_was_on;
2134:MyHardWare/eMPL/inv_mpu.c **** 
2135:MyHardWare/eMPL/inv_mpu.c ****   if (st.chip_cfg.dmp_on) {
2136:MyHardWare/eMPL/inv_mpu.c ****     mpu_set_dmp_state(0);
2137:MyHardWare/eMPL/inv_mpu.c ****     dmp_was_on = 1;
2138:MyHardWare/eMPL/inv_mpu.c ****   } else
2139:MyHardWare/eMPL/inv_mpu.c ****     dmp_was_on = 0;
2140:MyHardWare/eMPL/inv_mpu.c **** 
2141:MyHardWare/eMPL/inv_mpu.c ****   /* Get initial settings. */
2142:MyHardWare/eMPL/inv_mpu.c ****   mpu_get_gyro_fsr(&gyro_fsr);
2143:MyHardWare/eMPL/inv_mpu.c ****   mpu_get_accel_fsr(&accel_fsr);
2144:MyHardWare/eMPL/inv_mpu.c ****   mpu_get_lpf(&lpf);
2145:MyHardWare/eMPL/inv_mpu.c ****   mpu_get_sample_rate(&sample_rate);
2146:MyHardWare/eMPL/inv_mpu.c ****   sensors_on = st.chip_cfg.sensors;
2147:MyHardWare/eMPL/inv_mpu.c ****   mpu_get_fifo_config(&fifo_sensors);
2148:MyHardWare/eMPL/inv_mpu.c **** 
2149:MyHardWare/eMPL/inv_mpu.c ****   /* For older chips, the self-test will be different. */
2150:MyHardWare/eMPL/inv_mpu.c **** #if defined MPU6050
2151:MyHardWare/eMPL/inv_mpu.c ****   for (ii = 0; ii < tries; ii++)
2152:MyHardWare/eMPL/inv_mpu.c ****     if (!get_st_biases(gyro, accel, 0))
2153:MyHardWare/eMPL/inv_mpu.c ****       break;
2154:MyHardWare/eMPL/inv_mpu.c ****   if (ii == tries) {
2155:MyHardWare/eMPL/inv_mpu.c ****     /* If we reach this point, we most likely encountered an I2C error.
2156:MyHardWare/eMPL/inv_mpu.c ****      * We'll just report an error for all three sensors.
2157:MyHardWare/eMPL/inv_mpu.c ****      */
2158:MyHardWare/eMPL/inv_mpu.c ****     result = 0;
2159:MyHardWare/eMPL/inv_mpu.c ****     goto restore;
2160:MyHardWare/eMPL/inv_mpu.c ****   }
2161:MyHardWare/eMPL/inv_mpu.c ****   for (ii = 0; ii < tries; ii++)
2162:MyHardWare/eMPL/inv_mpu.c ****     if (!get_st_biases(gyro_st, accel_st, 1))
2163:MyHardWare/eMPL/inv_mpu.c ****       break;
ARM GAS  C:\Users\asus\AppData\Local\Temp\ccirS3Oi.s 			page 172


2164:MyHardWare/eMPL/inv_mpu.c ****   if (ii == tries) {
2165:MyHardWare/eMPL/inv_mpu.c ****     /* Again, probably an I2C error. */
2166:MyHardWare/eMPL/inv_mpu.c ****     result = 0;
2167:MyHardWare/eMPL/inv_mpu.c ****     goto restore;
2168:MyHardWare/eMPL/inv_mpu.c ****   }
2169:MyHardWare/eMPL/inv_mpu.c ****   accel_result = accel_self_test(accel, accel_st);
2170:MyHardWare/eMPL/inv_mpu.c ****   gyro_result = gyro_self_test(gyro, gyro_st);
2171:MyHardWare/eMPL/inv_mpu.c **** 
2172:MyHardWare/eMPL/inv_mpu.c ****   result = 0;
2173:MyHardWare/eMPL/inv_mpu.c ****   if (!gyro_result)
2174:MyHardWare/eMPL/inv_mpu.c ****     result |= 0x01;
2175:MyHardWare/eMPL/inv_mpu.c ****   if (!accel_result)
2176:MyHardWare/eMPL/inv_mpu.c ****     result |= 0x02;
2177:MyHardWare/eMPL/inv_mpu.c **** 
2178:MyHardWare/eMPL/inv_mpu.c **** #ifdef AK89xx_SECONDARY
2179:MyHardWare/eMPL/inv_mpu.c ****   compass_result = compass_self_test();
2180:MyHardWare/eMPL/inv_mpu.c ****   if (!compass_result)
2181:MyHardWare/eMPL/inv_mpu.c ****     result |= 0x04;
2182:MyHardWare/eMPL/inv_mpu.c **** #endif
2183:MyHardWare/eMPL/inv_mpu.c **** restore:
2184:MyHardWare/eMPL/inv_mpu.c **** #elif defined MPU6500
2185:MyHardWare/eMPL/inv_mpu.c ****   /* For now, this function will return a "pass" result for all three sensors
2186:MyHardWare/eMPL/inv_mpu.c ****    * for compatibility with current test applications.
2187:MyHardWare/eMPL/inv_mpu.c ****    */
2188:MyHardWare/eMPL/inv_mpu.c ****   get_st_biases(gyro, accel, 0);
2189:MyHardWare/eMPL/inv_mpu.c ****   result = 0x7;
2190:MyHardWare/eMPL/inv_mpu.c **** #endif
2191:MyHardWare/eMPL/inv_mpu.c ****   /* Set to invalid values to ensure no I2C writes are skipped. */
2192:MyHardWare/eMPL/inv_mpu.c ****   st.chip_cfg.gyro_fsr = 0xFF;
2193:MyHardWare/eMPL/inv_mpu.c ****   st.chip_cfg.accel_fsr = 0xFF;
2194:MyHardWare/eMPL/inv_mpu.c ****   st.chip_cfg.lpf = 0xFF;
2195:MyHardWare/eMPL/inv_mpu.c ****   st.chip_cfg.sample_rate = 0xFFFF;
2196:MyHardWare/eMPL/inv_mpu.c ****   st.chip_cfg.sensors = 0xFF;
2197:MyHardWare/eMPL/inv_mpu.c ****   st.chip_cfg.fifo_enable = 0xFF;
2198:MyHardWare/eMPL/inv_mpu.c ****   st.chip_cfg.clk_src = INV_CLK_PLL;
2199:MyHardWare/eMPL/inv_mpu.c ****   mpu_set_gyro_fsr(gyro_fsr);
2200:MyHardWare/eMPL/inv_mpu.c ****   mpu_set_accel_fsr(accel_fsr);
2201:MyHardWare/eMPL/inv_mpu.c ****   mpu_set_lpf(lpf);
2202:MyHardWare/eMPL/inv_mpu.c ****   mpu_set_sample_rate(sample_rate);
2203:MyHardWare/eMPL/inv_mpu.c ****   mpu_set_sensors(sensors_on);
2204:MyHardWare/eMPL/inv_mpu.c ****   mpu_configure_fifo(fifo_sensors);
2205:MyHardWare/eMPL/inv_mpu.c **** 
2206:MyHardWare/eMPL/inv_mpu.c ****   if (dmp_was_on)
