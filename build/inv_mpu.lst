2239:MyHardWare/eMPL/inv_mpu.c **** #elif defined MPU6500
2240:MyHardWare/eMPL/inv_mpu.c ****     /* For now, this function will return a "pass" result for all three sensors
2241:MyHardWare/eMPL/inv_mpu.c ****      * for compatibility with current test applications.
2242:MyHardWare/eMPL/inv_mpu.c ****      */
2243:MyHardWare/eMPL/inv_mpu.c ****     get_st_biases(gyro, accel, 0);
2244:MyHardWare/eMPL/inv_mpu.c ****     result = 0x7;
2245:MyHardWare/eMPL/inv_mpu.c **** #endif
