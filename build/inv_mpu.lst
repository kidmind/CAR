2845:MyHardWare/eMPL/inv_mpu.c ****    */
2846:MyHardWare/eMPL/inv_mpu.c **** 
2847:MyHardWare/eMPL/inv_mpu.c ****   scalar = inv_row_2_scale(mtx);
2848:MyHardWare/eMPL/inv_mpu.c ****   scalar |= inv_row_2_scale(mtx + 3) << 3;
2849:MyHardWare/eMPL/inv_mpu.c ****   scalar |= inv_row_2_scale(mtx + 6) << 6;
2850:MyHardWare/eMPL/inv_mpu.c **** 
2851:MyHardWare/eMPL/inv_mpu.c ****   return scalar;
2852:MyHardWare/eMPL/inv_mpu.c **** }
