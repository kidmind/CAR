2223:MyHardWare/eMPL/inv_mpu.c ****     }
2224:MyHardWare/eMPL/inv_mpu.c ****     accel_result = accel_self_test(accel, accel_st);
2225:MyHardWare/eMPL/inv_mpu.c ****     gyro_result = gyro_self_test(gyro, gyro_st);
2226:MyHardWare/eMPL/inv_mpu.c **** 
2227:MyHardWare/eMPL/inv_mpu.c ****     result = 0;
2228:MyHardWare/eMPL/inv_mpu.c ****     if (!gyro_result)
