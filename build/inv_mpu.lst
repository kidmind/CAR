 729:MyHardWare/eMPL/inv_mpu.c **** /**
 730:MyHardWare/eMPL/inv_mpu.c ****  *  @brief      Initialize hardware.
 731:MyHardWare/eMPL/inv_mpu.c ****  *  Initial configuration:\n
 732:MyHardWare/eMPL/inv_mpu.c ****  *  Gyro FSR: +/- 2000DPS\n
 733:MyHardWare/eMPL/inv_mpu.c ****  *  Accel FSR +/- 2G\n
 734:MyHardWare/eMPL/inv_mpu.c ****  *  DLPF: 42Hz\n
 735:MyHardWare/eMPL/inv_mpu.c ****  *  FIFO rate: 50Hz\n
 736:MyHardWare/eMPL/inv_mpu.c ****  *  Clock source: Gyro PLL\n
 737:MyHardWare/eMPL/inv_mpu.c ****  *  FIFO: Disabled.\n
 738:MyHardWare/eMPL/inv_mpu.c ****  *  Data ready interrupt: Disabled, active low, unlatched.
 739:MyHardWare/eMPL/inv_mpu.c ****  *  @param[in]  int_param   Platform-specific parameters to interrupt API.
 740:MyHardWare/eMPL/inv_mpu.c ****  *  @return     0 if successful.
 741:MyHardWare/eMPL/inv_mpu.c ****  */
 742:MyHardWare/eMPL/inv_mpu.c **** int mpu_init(void) {
 743:MyHardWare/eMPL/inv_mpu.c ****   unsigned char data[6], rev;
 744:MyHardWare/eMPL/inv_mpu.c **** 
 745:MyHardWare/eMPL/inv_mpu.c ****   /* Reset device. */
 746:MyHardWare/eMPL/inv_mpu.c ****   data[0] = BIT_RESET;
 747:MyHardWare/eMPL/inv_mpu.c ****   if (i2c_write(st.hw->addr, st.reg->pwr_mgmt_1, 1, data))
 748:MyHardWare/eMPL/inv_mpu.c ****     return -1;
 749:MyHardWare/eMPL/inv_mpu.c ****   delay_ms(100);
 750:MyHardWare/eMPL/inv_mpu.c **** 
 751:MyHardWare/eMPL/inv_mpu.c ****   /* Wake up chip. */
 752:MyHardWare/eMPL/inv_mpu.c ****   data[0] = 0x00;
 753:MyHardWare/eMPL/inv_mpu.c ****   if (i2c_write(st.hw->addr, st.reg->pwr_mgmt_1, 1, data))
 754:MyHardWare/eMPL/inv_mpu.c ****     return -1;
 755:MyHardWare/eMPL/inv_mpu.c **** 
 756:MyHardWare/eMPL/inv_mpu.c **** #if defined MPU6050
 757:MyHardWare/eMPL/inv_mpu.c ****   /* Check product revision. */
 758:MyHardWare/eMPL/inv_mpu.c ****   if (i2c_read(st.hw->addr, st.reg->accel_offs, 6, data))
 759:MyHardWare/eMPL/inv_mpu.c ****     return -1;
 760:MyHardWare/eMPL/inv_mpu.c ****   rev = ((data[5] & 0x01) << 2) | ((data[3] & 0x01) << 1) | (data[1] & 0x01);
 761:MyHardWare/eMPL/inv_mpu.c **** 
 762:MyHardWare/eMPL/inv_mpu.c ****   if (rev) {
 763:MyHardWare/eMPL/inv_mpu.c ****     /* Congrats, these parts are better. */
 764:MyHardWare/eMPL/inv_mpu.c ****     if (rev == 1)
 765:MyHardWare/eMPL/inv_mpu.c ****       st.chip_cfg.accel_half = 1;
 766:MyHardWare/eMPL/inv_mpu.c ****     else if (rev == 2)
 767:MyHardWare/eMPL/inv_mpu.c ****       st.chip_cfg.accel_half = 0;
 768:MyHardWare/eMPL/inv_mpu.c ****     else {
 769:MyHardWare/eMPL/inv_mpu.c ****       log_e("Unsupported software product rev %d.\n", rev);
 770:MyHardWare/eMPL/inv_mpu.c ****       return -1;
 771:MyHardWare/eMPL/inv_mpu.c ****     }
ARM GAS  C:\Users\asus\AppData\Local\Temp\ccirS3Oi.s 			page 15


 772:MyHardWare/eMPL/inv_mpu.c ****   } else {
 773:MyHardWare/eMPL/inv_mpu.c ****     if (i2c_read(st.hw->addr, st.reg->prod_id, 1, data))
 774:MyHardWare/eMPL/inv_mpu.c ****       return -1;
 775:MyHardWare/eMPL/inv_mpu.c ****     rev = data[0] & 0x0F;
 776:MyHardWare/eMPL/inv_mpu.c ****     if (!rev) {
 777:MyHardWare/eMPL/inv_mpu.c ****       log_e("Product ID read as 0 indicates device is either "
 778:MyHardWare/eMPL/inv_mpu.c ****             "incompatible or an MPU3050.\n");
 779:MyHardWare/eMPL/inv_mpu.c ****       return -1;
 780:MyHardWare/eMPL/inv_mpu.c ****     } else if (rev == 4) {
 781:MyHardWare/eMPL/inv_mpu.c ****       log_i("Half sensitivity part found.\n");
 782:MyHardWare/eMPL/inv_mpu.c ****       st.chip_cfg.accel_half = 1;
 783:MyHardWare/eMPL/inv_mpu.c ****     } else
 784:MyHardWare/eMPL/inv_mpu.c ****       st.chip_cfg.accel_half = 0;
