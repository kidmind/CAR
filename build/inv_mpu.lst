 662:MyHardWare/eMPL/inv_mpu.c **** /**
 663:MyHardWare/eMPL/inv_mpu.c ****  *  @brief      Enable/disable data ready interrupt.
 664:MyHardWare/eMPL/inv_mpu.c ****  *  If the DMP is on, the DMP interrupt is enabled. Otherwise, the data ready
 665:MyHardWare/eMPL/inv_mpu.c ****  *  interrupt is used.
 666:MyHardWare/eMPL/inv_mpu.c ****  *  @param[in]  enable      1 to enable interrupt.
 667:MyHardWare/eMPL/inv_mpu.c ****  *  @return     0 if successful.
 668:MyHardWare/eMPL/inv_mpu.c ****  */
 669:MyHardWare/eMPL/inv_mpu.c **** static int set_int_enable(unsigned char enable) {
 670:MyHardWare/eMPL/inv_mpu.c ****   unsigned char tmp;
 671:MyHardWare/eMPL/inv_mpu.c **** 
 672:MyHardWare/eMPL/inv_mpu.c ****   if (st.chip_cfg.dmp_on) {
 673:MyHardWare/eMPL/inv_mpu.c ****     if (enable)
 674:MyHardWare/eMPL/inv_mpu.c ****       tmp = BIT_DMP_INT_EN;
 675:MyHardWare/eMPL/inv_mpu.c ****     else
 676:MyHardWare/eMPL/inv_mpu.c ****       tmp = 0x00;
 677:MyHardWare/eMPL/inv_mpu.c ****     if (i2c_write(st.hw->addr, st.reg->int_enable, 1, &tmp))
 678:MyHardWare/eMPL/inv_mpu.c ****       return -1;
 679:MyHardWare/eMPL/inv_mpu.c ****     st.chip_cfg.int_enable = tmp;
 680:MyHardWare/eMPL/inv_mpu.c ****   } else {
 681:MyHardWare/eMPL/inv_mpu.c ****     if (!st.chip_cfg.sensors)
 682:MyHardWare/eMPL/inv_mpu.c ****       return -1;
 683:MyHardWare/eMPL/inv_mpu.c ****     if (enable && st.chip_cfg.int_enable)
 684:MyHardWare/eMPL/inv_mpu.c ****       return 0;
 685:MyHardWare/eMPL/inv_mpu.c ****     if (enable)
 686:MyHardWare/eMPL/inv_mpu.c ****       tmp = BIT_DATA_RDY_EN;
 687:MyHardWare/eMPL/inv_mpu.c ****     else
 688:MyHardWare/eMPL/inv_mpu.c ****       tmp = 0x00;
 689:MyHardWare/eMPL/inv_mpu.c ****     if (i2c_write(st.hw->addr, st.reg->int_enable, 1, &tmp))
 690:MyHardWare/eMPL/inv_mpu.c ****       return -1;
 691:MyHardWare/eMPL/inv_mpu.c ****     st.chip_cfg.int_enable = tmp;
 692:MyHardWare/eMPL/inv_mpu.c ****   }
 693:MyHardWare/eMPL/inv_mpu.c ****   return 0;
 694:MyHardWare/eMPL/inv_mpu.c **** }
 695:MyHardWare/eMPL/inv_mpu.c **** 
