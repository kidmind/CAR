2154:MyHardWare/eMPL/inv_mpu.c **** /**
2155:MyHardWare/eMPL/inv_mpu.c ****  *  @brief      Trigger gyro/accel/compass self-test.
2156:MyHardWare/eMPL/inv_mpu.c ****  *  On success/error, the self-test returns a mask representing the sensor(s)
2157:MyHardWare/eMPL/inv_mpu.c ****  *  that failed. For each bit, a one (1) represents a "pass" case; conversely,
2158:MyHardWare/eMPL/inv_mpu.c ****  *  a zero (0) indicates a failure.
2159:MyHardWare/eMPL/inv_mpu.c ****  *
2160:MyHardWare/eMPL/inv_mpu.c ****  *  \n The mask is defined as follows:
2161:MyHardWare/eMPL/inv_mpu.c ****  *  \n Bit 0:   Gyro.
2162:MyHardWare/eMPL/inv_mpu.c ****  *  \n Bit 1:   Accel.
2163:MyHardWare/eMPL/inv_mpu.c ****  *  \n Bit 2:   Compass.
ARM GAS  /tmp/ccs1piim.s 			page 172


2164:MyHardWare/eMPL/inv_mpu.c ****  *
2165:MyHardWare/eMPL/inv_mpu.c ****  *  \n Currently, the hardware self-test is unsupported for MPU6500. However,
2166:MyHardWare/eMPL/inv_mpu.c ****  *  this function can still be used to obtain the accel and gyro biases.
2167:MyHardWare/eMPL/inv_mpu.c ****  *
2168:MyHardWare/eMPL/inv_mpu.c ****  *  \n This function must be called with the device either face-up or face-down
2169:MyHardWare/eMPL/inv_mpu.c ****  *  (z-axis is parallel to gravity).
2170:MyHardWare/eMPL/inv_mpu.c ****  *  @param[out] gyro        Gyro biases in q16 format.
2171:MyHardWare/eMPL/inv_mpu.c ****  *  @param[out] accel       Accel biases (if applicable) in q16 format.
2172:MyHardWare/eMPL/inv_mpu.c ****  *  @return     Result mask (see above).
2173:MyHardWare/eMPL/inv_mpu.c ****  */
2174:MyHardWare/eMPL/inv_mpu.c **** int mpu_run_self_test(long *gyro, long *accel)
2175:MyHardWare/eMPL/inv_mpu.c **** {
2176:MyHardWare/eMPL/inv_mpu.c **** #ifdef MPU6050
2177:MyHardWare/eMPL/inv_mpu.c ****     const unsigned char tries = 2;
2178:MyHardWare/eMPL/inv_mpu.c ****     long gyro_st[3], accel_st[3];
2179:MyHardWare/eMPL/inv_mpu.c ****     unsigned char accel_result, gyro_result;
2180:MyHardWare/eMPL/inv_mpu.c **** #ifdef AK89xx_SECONDARY
2181:MyHardWare/eMPL/inv_mpu.c ****     unsigned char compass_result;
2182:MyHardWare/eMPL/inv_mpu.c **** #endif
2183:MyHardWare/eMPL/inv_mpu.c ****     int ii;
2184:MyHardWare/eMPL/inv_mpu.c **** #endif
