 679:MyHardWare/eMPL/inv_mpu.c **** /**
 680:MyHardWare/eMPL/inv_mpu.c ****  *  @brief      Enable/disable data ready interrupt.
 681:MyHardWare/eMPL/inv_mpu.c ****  *  If the DMP is on, the DMP interrupt is enabled. Otherwise, the data ready
 682:MyHardWare/eMPL/inv_mpu.c ****  *  interrupt is used.
 683:MyHardWare/eMPL/inv_mpu.c ****  *  @param[in]  enable      1 to enable interrupt.
 684:MyHardWare/eMPL/inv_mpu.c ****  *  @return     0 if successful.
 685:MyHardWare/eMPL/inv_mpu.c ****  */
 686:MyHardWare/eMPL/inv_mpu.c **** static int set_int_enable(unsigned char enable)
 687:MyHardWare/eMPL/inv_mpu.c **** {
 688:MyHardWare/eMPL/inv_mpu.c ****     unsigned char tmp;
 689:MyHardWare/eMPL/inv_mpu.c **** 
 690:MyHardWare/eMPL/inv_mpu.c ****     if (st.chip_cfg.dmp_on) {
 691:MyHardWare/eMPL/inv_mpu.c ****         if (enable)
 692:MyHardWare/eMPL/inv_mpu.c ****             tmp = BIT_DMP_INT_EN;
 693:MyHardWare/eMPL/inv_mpu.c ****         else
 694:MyHardWare/eMPL/inv_mpu.c ****             tmp = 0x00;
 695:MyHardWare/eMPL/inv_mpu.c ****         if (i2c_write(st.hw->addr, st.reg->int_enable, 1, &tmp))
 696:MyHardWare/eMPL/inv_mpu.c ****             return -1;
 697:MyHardWare/eMPL/inv_mpu.c ****         st.chip_cfg.int_enable = tmp;
 698:MyHardWare/eMPL/inv_mpu.c ****     } else {
 699:MyHardWare/eMPL/inv_mpu.c ****         if (!st.chip_cfg.sensors)
 700:MyHardWare/eMPL/inv_mpu.c ****             return -1;
 701:MyHardWare/eMPL/inv_mpu.c ****         if (enable && st.chip_cfg.int_enable)
 702:MyHardWare/eMPL/inv_mpu.c ****             return 0;
 703:MyHardWare/eMPL/inv_mpu.c ****         if (enable)
 704:MyHardWare/eMPL/inv_mpu.c ****             tmp = BIT_DATA_RDY_EN;
 705:MyHardWare/eMPL/inv_mpu.c ****         else
 706:MyHardWare/eMPL/inv_mpu.c ****             tmp = 0x00;
 707:MyHardWare/eMPL/inv_mpu.c ****         if (i2c_write(st.hw->addr, st.reg->int_enable, 1, &tmp))
 708:MyHardWare/eMPL/inv_mpu.c ****             return -1;
 709:MyHardWare/eMPL/inv_mpu.c ****         st.chip_cfg.int_enable = tmp;
 710:MyHardWare/eMPL/inv_mpu.c ****     }
 711:MyHardWare/eMPL/inv_mpu.c ****     return 0;
 712:MyHardWare/eMPL/inv_mpu.c **** }
