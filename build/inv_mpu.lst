2539:MyHardWare/eMPL/inv_mpu.c **** /**
2540:MyHardWare/eMPL/inv_mpu.c ****  *  @brief      Enters LP accel motion interrupt mode.
2541:MyHardWare/eMPL/inv_mpu.c ****  *  The behavior of this feature is very different between the MPU6050 and the
2542:MyHardWare/eMPL/inv_mpu.c ****  *  MPU6500. Each chip's version of this feature is explained below.
2543:MyHardWare/eMPL/inv_mpu.c ****  *
2544:MyHardWare/eMPL/inv_mpu.c ****  *  \n MPU6050:
2545:MyHardWare/eMPL/inv_mpu.c ****  *  \n When this mode is first enabled, the hardware captures a single accel
2546:MyHardWare/eMPL/inv_mpu.c ****  *  sample, and subsequent samples are compared with this one to determine if
2547:MyHardWare/eMPL/inv_mpu.c ****  *  the device is in motion. Therefore, whenever this "locked" sample needs to
2548:MyHardWare/eMPL/inv_mpu.c ****  *  be changed, this function must be called again.
2549:MyHardWare/eMPL/inv_mpu.c ****  *
2550:MyHardWare/eMPL/inv_mpu.c ****  *  \n The hardware motion threshold can be between 32mg and 8160mg in 32mg
2551:MyHardWare/eMPL/inv_mpu.c ****  *  increments.
2552:MyHardWare/eMPL/inv_mpu.c ****  *
2553:MyHardWare/eMPL/inv_mpu.c ****  *  \n Low-power accel mode supports the following frequencies:
2554:MyHardWare/eMPL/inv_mpu.c ****  *  \n 1.25Hz, 5Hz, 20Hz, 40Hz
2555:MyHardWare/eMPL/inv_mpu.c ****  *
2556:MyHardWare/eMPL/inv_mpu.c ****  *  \n MPU6500:
2557:MyHardWare/eMPL/inv_mpu.c ****  *  \n Unlike the MPU6050 version, the hardware does not "lock in" a reference
2558:MyHardWare/eMPL/inv_mpu.c ****  *  sample. The hardware monitors the accel data and detects any large change
2559:MyHardWare/eMPL/inv_mpu.c ****  *  over a short period of time.
2560:MyHardWare/eMPL/inv_mpu.c ****  *
2561:MyHardWare/eMPL/inv_mpu.c ****  *  \n The hardware motion threshold can be between 4mg and 1020mg in 4mg
2562:MyHardWare/eMPL/inv_mpu.c ****  *  increments.
2563:MyHardWare/eMPL/inv_mpu.c ****  *
2564:MyHardWare/eMPL/inv_mpu.c ****  *  \n MPU6500 Low-power accel mode supports the following frequencies:
2565:MyHardWare/eMPL/inv_mpu.c ****  *  \n 1.25Hz, 2.5Hz, 5Hz, 10Hz, 20Hz, 40Hz, 80Hz, 160Hz, 320Hz, 640Hz
2566:MyHardWare/eMPL/inv_mpu.c ****  *
2567:MyHardWare/eMPL/inv_mpu.c ****  *  \n\n NOTES:
2568:MyHardWare/eMPL/inv_mpu.c ****  *  \n The driver will round down @e thresh to the nearest supported value if
2569:MyHardWare/eMPL/inv_mpu.c ****  *  an unsupported threshold is selected.
2570:MyHardWare/eMPL/inv_mpu.c ****  *  \n To select a fractional wake-up frequency, round down the value passed to
2571:MyHardWare/eMPL/inv_mpu.c ****  *  @e lpa_freq.
2572:MyHardWare/eMPL/inv_mpu.c ****  *  \n The MPU6500 does not support a delay parameter. If this function is used
2573:MyHardWare/eMPL/inv_mpu.c ****  *  for the MPU6500, the value passed to @e time will be ignored.
2574:MyHardWare/eMPL/inv_mpu.c ****  *  \n To disable this mode, set @e lpa_freq to zero. The driver will restore
2575:MyHardWare/eMPL/inv_mpu.c ****  *  the previous configuration.
2576:MyHardWare/eMPL/inv_mpu.c ****  *
2577:MyHardWare/eMPL/inv_mpu.c ****  *  @param[in]  thresh      Motion threshold in mg.
2578:MyHardWare/eMPL/inv_mpu.c ****  *  @param[in]  time        Duration in milliseconds that the accel data must
2579:MyHardWare/eMPL/inv_mpu.c ****  *                          exceed @e thresh before motion is reported.
2580:MyHardWare/eMPL/inv_mpu.c ****  *  @param[in]  lpa_freq    Minimum sampling rate, or zero to disable.
2581:MyHardWare/eMPL/inv_mpu.c ****  *  @return     0 if successful.
2582:MyHardWare/eMPL/inv_mpu.c ****  */
2583:MyHardWare/eMPL/inv_mpu.c **** int mpu_lp_motion_interrupt(unsigned short thresh, unsigned char time,
2584:MyHardWare/eMPL/inv_mpu.c ****                             unsigned char lpa_freq) {
