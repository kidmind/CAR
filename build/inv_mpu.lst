2186:MyHardWare/eMPL/inv_mpu.c ****     unsigned char accel_fsr, fifo_sensors, sensors_on;
2187:MyHardWare/eMPL/inv_mpu.c ****     unsigned short gyro_fsr, sample_rate, lpf;
2188:MyHardWare/eMPL/inv_mpu.c ****     unsigned char dmp_was_on;
2189:MyHardWare/eMPL/inv_mpu.c **** 
2190:MyHardWare/eMPL/inv_mpu.c ****     if (st.chip_cfg.dmp_on) {
2191:MyHardWare/eMPL/inv_mpu.c ****         mpu_set_dmp_state(0);
2192:MyHardWare/eMPL/inv_mpu.c ****         dmp_was_on = 1;
2193:MyHardWare/eMPL/inv_mpu.c ****     } else
2194:MyHardWare/eMPL/inv_mpu.c ****         dmp_was_on = 0;
2195:MyHardWare/eMPL/inv_mpu.c **** 
2196:MyHardWare/eMPL/inv_mpu.c ****     /* Get initial settings. */
2197:MyHardWare/eMPL/inv_mpu.c ****     mpu_get_gyro_fsr(&gyro_fsr);
2198:MyHardWare/eMPL/inv_mpu.c ****     mpu_get_accel_fsr(&accel_fsr);
2199:MyHardWare/eMPL/inv_mpu.c ****     mpu_get_lpf(&lpf);
2200:MyHardWare/eMPL/inv_mpu.c ****     mpu_get_sample_rate(&sample_rate);
2201:MyHardWare/eMPL/inv_mpu.c ****     sensors_on = st.chip_cfg.sensors;
2202:MyHardWare/eMPL/inv_mpu.c ****     mpu_get_fifo_config(&fifo_sensors);
2203:MyHardWare/eMPL/inv_mpu.c **** 
2204:MyHardWare/eMPL/inv_mpu.c ****     /* For older chips, the self-test will be different. */
2205:MyHardWare/eMPL/inv_mpu.c **** #if defined MPU6050
2206:MyHardWare/eMPL/inv_mpu.c ****     for (ii = 0; ii < tries; ii++)
2207:MyHardWare/eMPL/inv_mpu.c ****         if (!get_st_biases(gyro, accel, 0))
2208:MyHardWare/eMPL/inv_mpu.c ****             break;
2209:MyHardWare/eMPL/inv_mpu.c ****     if (ii == tries) {
2210:MyHardWare/eMPL/inv_mpu.c ****         /* If we reach this point, we most likely encountered an I2C error.
