 902:MyHardWare/eMPL/inv_mpu.c ****   } else if (rate <= 20) {
 903:MyHardWare/eMPL/inv_mpu.c ****     tmp[1] = INV_LPA_20HZ;
 904:MyHardWare/eMPL/inv_mpu.c ****     mpu_set_lpf(10);
 905:MyHardWare/eMPL/inv_mpu.c ****   } else {
 906:MyHardWare/eMPL/inv_mpu.c ****     tmp[1] = INV_LPA_40HZ;
 907:MyHardWare/eMPL/inv_mpu.c ****     mpu_set_lpf(20);
 908:MyHardWare/eMPL/inv_mpu.c ****   }
 909:MyHardWare/eMPL/inv_mpu.c ****   tmp[1] = (tmp[1] << 6) | BIT_STBY_XYZG;
