2611:MyHardWare/Src/sdio_sd.c ****   }
2612:MyHardWare/Src/sdio_sd.c **** 
2613:MyHardWare/Src/sdio_sd.c ****   /*!< If wide bus operation to be enabled */
2614:MyHardWare/Src/sdio_sd.c ****   if (NewState == ENABLE)
2615:MyHardWare/Src/sdio_sd.c ****   {
