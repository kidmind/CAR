 469:CMSIS/system_stm32f4xx.c **** /**
 470:CMSIS/system_stm32f4xx.c ****   * @brief  Setup the microcontroller system
 471:CMSIS/system_stm32f4xx.c ****   *         Initialize the Embedded Flash Interface, the PLL and update the 
 472:CMSIS/system_stm32f4xx.c ****   *         SystemFrequency variable.
 473:CMSIS/system_stm32f4xx.c ****   * @param  None
 474:CMSIS/system_stm32f4xx.c ****   * @retval None
 475:CMSIS/system_stm32f4xx.c ****   */
 476:CMSIS/system_stm32f4xx.c **** void SystemInit(void)
 477:CMSIS/system_stm32f4xx.c **** {
 478:CMSIS/system_stm32f4xx.c ****   /* FPU settings ------------------------------------------------------------*/
 479:CMSIS/system_stm32f4xx.c ****   #if (__FPU_PRESENT == 1) && (__FPU_USED == 1)
 480:CMSIS/system_stm32f4xx.c ****     SCB->CPACR |= ((3UL << 10*2)|(3UL << 11*2));  /* set CP10 and CP11 Full Access */
 481:CMSIS/system_stm32f4xx.c ****   #endif
 482:CMSIS/system_stm32f4xx.c ****   /* Reset the RCC clock configuration to the default reset state ------------*/
 483:CMSIS/system_stm32f4xx.c ****   /* Set HSION bit */
 484:CMSIS/system_stm32f4xx.c ****   RCC->CR |= (uint32_t)0x00000001;
 485:CMSIS/system_stm32f4xx.c **** 
 486:CMSIS/system_stm32f4xx.c ****   /* Reset CFGR register */
 487:CMSIS/system_stm32f4xx.c ****   RCC->CFGR = 0x00000000;
ARM GAS  /tmp/cc2bu7Wx.s 			page 10


 488:CMSIS/system_stm32f4xx.c **** 
 489:CMSIS/system_stm32f4xx.c ****   /* Reset HSEON, CSSON and PLLON bits */
 490:CMSIS/system_stm32f4xx.c ****   RCC->CR &= (uint32_t)0xFEF6FFFF;
 491:CMSIS/system_stm32f4xx.c **** 
 492:CMSIS/system_stm32f4xx.c ****   /* Reset PLLCFGR register */
 493:CMSIS/system_stm32f4xx.c ****   RCC->PLLCFGR = 0x24003010;
 494:CMSIS/system_stm32f4xx.c **** 
 495:CMSIS/system_stm32f4xx.c ****   /* Reset HSEBYP bit */
 496:CMSIS/system_stm32f4xx.c ****   RCC->CR &= (uint32_t)0xFFFBFFFF;
 497:CMSIS/system_stm32f4xx.c **** 
 498:CMSIS/system_stm32f4xx.c ****   /* Disable all interrupts */
 499:CMSIS/system_stm32f4xx.c ****   RCC->CIR = 0x00000000;
 500:CMSIS/system_stm32f4xx.c **** 
 501:CMSIS/system_stm32f4xx.c **** #if defined(DATA_IN_ExtSRAM) || defined(DATA_IN_ExtSDRAM)
 502:CMSIS/system_stm32f4xx.c ****   SystemInit_ExtMemCtl(); 
 503:CMSIS/system_stm32f4xx.c **** #endif /* DATA_IN_ExtSRAM || DATA_IN_ExtSDRAM */
 504:CMSIS/system_stm32f4xx.c ****          
 505:CMSIS/system_stm32f4xx.c ****   /* Configure the System clock source, PLL Multiplier and Divider factors, 
 506:CMSIS/system_stm32f4xx.c ****      AHB/APBx prescalers and Flash settings ----------------------------------*/
 507:CMSIS/system_stm32f4xx.c ****   SetSysClock();
 508:CMSIS/system_stm32f4xx.c **** 
 509:CMSIS/system_stm32f4xx.c ****   /* Configure the Vector Table location add offset address ------------------*/
 510:CMSIS/system_stm32f4xx.c **** #ifdef VECT_TAB_SRAM
 511:CMSIS/system_stm32f4xx.c ****   SCB->VTOR = SRAM_BASE | VECT_TAB_OFFSET; /* Vector Table Relocation in Internal SRAM */
 512:CMSIS/system_stm32f4xx.c **** #else
 513:CMSIS/system_stm32f4xx.c ****   SCB->VTOR = FLASH_BASE | VECT_TAB_OFFSET; /* Vector Table Relocation in Internal FLASH */
 514:CMSIS/system_stm32f4xx.c **** #endif
 515:CMSIS/system_stm32f4xx.c **** }
 516:CMSIS/system_stm32f4xx.c **** 
 517:CMSIS/system_stm32f4xx.c **** /**
 518:CMSIS/system_stm32f4xx.c ****    * @brief  Update SystemCoreClock variable according to Clock Register Values.
 519:CMSIS/system_stm32f4xx.c ****   *         The SystemCoreClock variable contains the core clock (HCLK), it can
 520:CMSIS/system_stm32f4xx.c ****   *         be used by the user application to setup the SysTick timer or configure
 521:CMSIS/system_stm32f4xx.c ****   *         other parameters.
 522:CMSIS/system_stm32f4xx.c ****   *           
 523:CMSIS/system_stm32f4xx.c ****   * @note   Each time the core clock (HCLK) changes, this function must be called
 524:CMSIS/system_stm32f4xx.c ****   *         to update SystemCoreClock variable value. Otherwise, any configuration
 525:CMSIS/system_stm32f4xx.c ****   *         based on this variable will be incorrect.         
 526:CMSIS/system_stm32f4xx.c ****   *     
 527:CMSIS/system_stm32f4xx.c ****   * @note   - The system frequency computed by this function is not the real 
 528:CMSIS/system_stm32f4xx.c ****   *           frequency in the chip. It is calculated based on the predefined 
 529:CMSIS/system_stm32f4xx.c ****   *           constant and the selected clock source:
 530:CMSIS/system_stm32f4xx.c ****   *             
 531:CMSIS/system_stm32f4xx.c ****   *           - If SYSCLK source is HSI, SystemCoreClock will contain the HSI_VALUE(*)
 532:CMSIS/system_stm32f4xx.c ****   *                                              
 533:CMSIS/system_stm32f4xx.c ****   *           - If SYSCLK source is HSE, SystemCoreClock will contain the HSE_VALUE(**)
 534:CMSIS/system_stm32f4xx.c ****   *                          
 535:CMSIS/system_stm32f4xx.c ****   *           - If SYSCLK source is PLL, SystemCoreClock will contain the HSE_VALUE(**) 
 536:CMSIS/system_stm32f4xx.c ****   *             or HSI_VALUE(*) multiplied/divided by the PLL factors.
 537:CMSIS/system_stm32f4xx.c ****   *         
 538:CMSIS/system_stm32f4xx.c ****   *         (*) HSI_VALUE is a constant defined in stm32f4xx.h file (default value
 539:CMSIS/system_stm32f4xx.c ****   *             16 MHz) but the real value may vary depending on the variations
 540:CMSIS/system_stm32f4xx.c ****   *             in voltage and temperature.   
 541:CMSIS/system_stm32f4xx.c ****   *    
 542:CMSIS/system_stm32f4xx.c ****   *         (**) HSE_VALUE is a constant defined in stm32f4xx.h file (default value
 543:CMSIS/system_stm32f4xx.c ****   *              25 MHz), user has to ensure that HSE_VALUE is same as the real
 544:CMSIS/system_stm32f4xx.c ****   *              frequency of the crystal used. Otherwise, this function may
ARM GAS  /tmp/cc2bu7Wx.s 			page 11


 545:CMSIS/system_stm32f4xx.c ****   *              have wrong result.
 546:CMSIS/system_stm32f4xx.c ****   *                
 547:CMSIS/system_stm32f4xx.c ****   *         - The result of this function could be not correct when using fractional
 548:CMSIS/system_stm32f4xx.c ****   *           value for HSE crystal.
 549:CMSIS/system_stm32f4xx.c ****   *     
 550:CMSIS/system_stm32f4xx.c ****   * @param  None
 551:CMSIS/system_stm32f4xx.c ****   * @retval None
 552:CMSIS/system_stm32f4xx.c ****   */
 553:CMSIS/system_stm32f4xx.c **** void SystemCoreClockUpdate(void)
 554:CMSIS/system_stm32f4xx.c **** {
 555:CMSIS/system_stm32f4xx.c ****   uint32_t tmp = 0, pllvco = 0, pllp = 2, pllsource = 0, pllm = 2;
 556:CMSIS/system_stm32f4xx.c **** #if defined(STM32F412xG) || defined(STM32F413_423xx) || defined(STM32F446xx)  
 557:CMSIS/system_stm32f4xx.c ****   uint32_t pllr = 2;
 558:CMSIS/system_stm32f4xx.c **** #endif /* STM32F412xG || STM32F413_423xx || STM32F446xx */
 559:CMSIS/system_stm32f4xx.c ****   /* Get SYSCLK source -------------------------------------------------------*/
 560:CMSIS/system_stm32f4xx.c ****   tmp = RCC->CFGR & RCC_CFGR_SWS;
 561:CMSIS/system_stm32f4xx.c **** 
 562:CMSIS/system_stm32f4xx.c ****   switch (tmp)
 563:CMSIS/system_stm32f4xx.c ****   {
 564:CMSIS/system_stm32f4xx.c ****     case 0x00:  /* HSI used as system clock source */
 565:CMSIS/system_stm32f4xx.c ****       SystemCoreClock = HSI_VALUE;
 566:CMSIS/system_stm32f4xx.c ****       break;
 567:CMSIS/system_stm32f4xx.c ****     case 0x04:  /* HSE used as system clock source */
 568:CMSIS/system_stm32f4xx.c ****       SystemCoreClock = HSE_VALUE;
 569:CMSIS/system_stm32f4xx.c ****       break;
