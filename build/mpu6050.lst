  95:MyHardWare/Src/mpu6050.c **** u8 MPU_Get_Temperature(void) {
  96:MyHardWare/Src/mpu6050.c ****   u8 res = 0, buf[2];
  97:MyHardWare/Src/mpu6050.c ****   short raw;
  98:MyHardWare/Src/mpu6050.c **** 
  99:MyHardWare/Src/mpu6050.c ****   res = MPU_Read_Len(MPU_ADDR, MPU_TEMP_OUTH_REG, 2, buf);
 100:MyHardWare/Src/mpu6050.c ****   if (res) {
 101:MyHardWare/Src/mpu6050.c ****     return res;
 102:MyHardWare/Src/mpu6050.c ****   }
 103:MyHardWare/Src/mpu6050.c ****   raw = ((u16)buf[0] << 8) | buf[1];
 104:MyHardWare/Src/mpu6050.c ****   temperature = 36.53 + ((double)raw) / 340;
 105:MyHardWare/Src/mpu6050.c ****   temperature *= 100;
 106:MyHardWare/Src/mpu6050.c ****   return 0;
 107:MyHardWare/Src/mpu6050.c **** }
