  58:MyHardWare/Src/mpu6050.c **** // 设置MPU6050的数字低通滤波器
  59:MyHardWare/Src/mpu6050.c **** // lpf:数字低通滤波频率(Hz)
  60:MyHardWare/Src/mpu6050.c **** // 返回值:0,设置成功
  61:MyHardWare/Src/mpu6050.c **** //     其他,设置失败
  62:MyHardWare/Src/mpu6050.c **** u8 MPU_Set_LPF(u16 lpf) {
  63:MyHardWare/Src/mpu6050.c ****   u8 data = 0;
  64:MyHardWare/Src/mpu6050.c ****   if (lpf >= 188)
  65:MyHardWare/Src/mpu6050.c ****     data = 1;
  66:MyHardWare/Src/mpu6050.c ****   else if (lpf >= 98)
  67:MyHardWare/Src/mpu6050.c ****     data = 2;
  68:MyHardWare/Src/mpu6050.c ****   else if (lpf >= 42)
  69:MyHardWare/Src/mpu6050.c ****     data = 3;
  70:MyHardWare/Src/mpu6050.c ****   else if (lpf >= 20)
  71:MyHardWare/Src/mpu6050.c ****     data = 4;
  72:MyHardWare/Src/mpu6050.c ****   else if (lpf >= 10)
  73:MyHardWare/Src/mpu6050.c ****     data = 5;
  74:MyHardWare/Src/mpu6050.c ****   else
  75:MyHardWare/Src/mpu6050.c ****     data = 6;
  76:MyHardWare/Src/mpu6050.c ****   return MPU_Write_Byte(MPU_CFG_REG, data); // 设置数字低通滤波器
  77:MyHardWare/Src/mpu6050.c **** }
