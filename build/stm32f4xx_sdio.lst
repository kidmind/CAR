 147:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 148:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Includes ------------------------------------------------------------------*/
 149:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #include "stm32f4xx_sdio.h"
 150:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #include "stm32f4xx_rcc.h"
 151:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 152:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /** @addtogroup STM32F4xx_StdPeriph_Driver
 153:Lib/StdPeriphs/src/stm32f4xx_sdio.c ****   * @{
 154:Lib/StdPeriphs/src/stm32f4xx_sdio.c ****   */
 155:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 156:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /** @defgroup SDIO 
 157:Lib/StdPeriphs/src/stm32f4xx_sdio.c ****   * @brief SDIO driver modules
 158:Lib/StdPeriphs/src/stm32f4xx_sdio.c ****   * @{
 159:Lib/StdPeriphs/src/stm32f4xx_sdio.c ****   */ 
 160:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 161:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Private typedef -----------------------------------------------------------*/
 162:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Private define ------------------------------------------------------------*/
 163:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 164:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* ------------ SDIO registers bit address in the alias region ----------- */
 165:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define SDIO_OFFSET                (SDIO_BASE - PERIPH_BASE)
 166:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 167:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* --- CLKCR Register ---*/
 168:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of CLKEN bit */
 169:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define CLKCR_OFFSET              (SDIO_OFFSET + 0x04)
 170:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define CLKEN_BitNumber           0x08
 171:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define CLKCR_CLKEN_BB            (PERIPH_BB_BASE + (CLKCR_OFFSET * 32) + (CLKEN_BitNumber * 4))
 172:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 173:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* --- CMD Register ---*/
 174:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of SDIOSUSPEND bit */
 175:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define CMD_OFFSET                (SDIO_OFFSET + 0x0C)
 176:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define SDIOSUSPEND_BitNumber     0x0B
 177:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define CMD_SDIOSUSPEND_BB        (PERIPH_BB_BASE + (CMD_OFFSET * 32) + (SDIOSUSPEND_BitNumber * 4)
 178:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 179:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of ENCMDCOMPL bit */
 180:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define ENCMDCOMPL_BitNumber      0x0C
 181:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define CMD_ENCMDCOMPL_BB         (PERIPH_BB_BASE + (CMD_OFFSET * 32) + (ENCMDCOMPL_BitNumber * 4))
 182:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 183:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of NIEN bit */
 184:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define NIEN_BitNumber            0x0D
 185:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define CMD_NIEN_BB               (PERIPH_BB_BASE + (CMD_OFFSET * 32) + (NIEN_BitNumber * 4))
 186:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 187:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of ATACMD bit */
 188:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define ATACMD_BitNumber          0x0E
 189:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define CMD_ATACMD_BB             (PERIPH_BB_BASE + (CMD_OFFSET * 32) + (ATACMD_BitNumber * 4))
 190:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 191:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* --- DCTRL Register ---*/
 192:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of DMAEN bit */
 193:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define DCTRL_OFFSET              (SDIO_OFFSET + 0x2C)
 194:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define DMAEN_BitNumber           0x03
 195:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define DCTRL_DMAEN_BB            (PERIPH_BB_BASE + (DCTRL_OFFSET * 32) + (DMAEN_BitNumber * 4))
 196:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 197:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of RWSTART bit */
 198:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define RWSTART_BitNumber         0x08
 199:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define DCTRL_RWSTART_BB          (PERIPH_BB_BASE + (DCTRL_OFFSET * 32) + (RWSTART_BitNumber * 4))
 200:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 201:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of RWSTOP bit */
ARM GAS  C:\Users\asus\AppData\Local\Temp\ccV61vMD.s 			page 5


 202:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define RWSTOP_BitNumber          0x09
 203:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define DCTRL_RWSTOP_BB           (PERIPH_BB_BASE + (DCTRL_OFFSET * 32) + (RWSTOP_BitNumber * 4))
 204:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 205:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of RWMOD bit */
 206:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define RWMOD_BitNumber           0x0A
 207:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define DCTRL_RWMOD_BB            (PERIPH_BB_BASE + (DCTRL_OFFSET * 32) + (RWMOD_BitNumber * 4))
 208:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** 
 209:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** /* Alias word address of SDIOEN bit */
 210:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define SDIOEN_BitNumber          0x0B
 211:Lib/StdPeriphs/src/stm32f4xx_sdio.c **** #define DCTRL_SDIOEN_BB           (PERIPH_BB_BASE + (DCTRL_OFFSET * 32) + (SDIOEN_BitNumber * 4))
