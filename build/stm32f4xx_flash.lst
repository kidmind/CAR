 747:Lib/StdPeriphs/src/stm32f4xx_flash.c **** 
 748:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   /* Wait for last operation to be completed */
 749:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   status = FLASH_WaitForLastOperation();
 750:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   
 751:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   if(status == FLASH_COMPLETE)
