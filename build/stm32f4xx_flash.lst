   1:Lib/StdPeriphs/src/stm32f4xx_flash.c **** /**
   2:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   ******************************************************************************
   3:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @file    stm32f4xx_flash.c
   4:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @author  MCD Application Team
   5:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @version V1.8.1
   6:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @date    27-January-2022
   7:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @brief   This file provides firmware functions to manage the following 
   8:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *          functionalities of the FLASH peripheral:
   9:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            + FLASH Interface configuration
  10:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            + FLASH Memory Programming
  11:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            + Option Bytes Programming
  12:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            + Interrupts and flags management
  13:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *  
  14:Lib/StdPeriphs/src/stm32f4xx_flash.c ****  @verbatim    
  15:Lib/StdPeriphs/src/stm32f4xx_flash.c ****  ===============================================================================
  16:Lib/StdPeriphs/src/stm32f4xx_flash.c ****                         ##### How to use this driver #####
  17:Lib/StdPeriphs/src/stm32f4xx_flash.c ****  ===============================================================================
  18:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     [..]                             
  19:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       This driver provides functions to configure and program the FLASH memory 
  20:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       of all STM32F4xx devices. These functions are split in 4 groups:
  21:Lib/StdPeriphs/src/stm32f4xx_flash.c ****    
  22:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (#) FLASH Interface configuration functions: this group includes the
  23:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           management of the following features:
  24:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Set the latency
  25:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Enable/Disable the prefetch buffer
  26:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Enable/Disable the Instruction cache and the Data cache
  27:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Reset the Instruction cache and the Data cache
  28:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     
  29:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (#) FLASH Memory Programming functions: this group includes all needed
ARM GAS  /tmp/ccGoYJQC.s 			page 2


  30:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           functions to erase and program the main memory:
  31:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Lock and Unlock the FLASH interface
  32:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Erase function: Erase sector, erase all sectors
  33:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Program functions: byte, half word, word and double word
  34:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     
  35:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (#) Option Bytes Programming functions: this group includes all needed
  36:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           functions to manage the Option Bytes:
  37:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Set/Reset the write protection
  38:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Set the Read protection Level
  39:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Set the BOR level
  40:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Program the user Option Bytes
  41:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Launch the Option Bytes loader
  42:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     
  43:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (#) Interrupts and flags management functions: this group 
  44:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           includes all needed functions to:
  45:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Enable/Disable the FLASH interrupt sources
  46:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Get flags status
  47:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Clear flags
  48:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Get FLASH operation status
  49:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) Wait for last FLASH operation   
  50:Lib/StdPeriphs/src/stm32f4xx_flash.c ****  @endverbatim
  51:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   ******************************************************************************
