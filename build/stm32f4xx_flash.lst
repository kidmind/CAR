 988:Lib/StdPeriphs/src/stm32f4xx_flash.c **** /**
 989:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @brief  Enables or disables the write protection of the desired sectors, for the first
 990:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         1 Mb of the Flash  
 991:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 992:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @note   When the memory read protection level is selected (RDP level = 1), 
 993:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         it is not possible to program or erase the flash sector i if CortexM4  
 994:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         debug features are connected or boot code is executed in RAM, even if nWRPi = 1 
 995:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @note   Active value of nWRPi bits is inverted when PCROP mode is active (SPRMOD =1).   
 996:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * 
 997:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @param  OB_WRP: specifies the sector(s) to be write protected or unprotected.
 998:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *          This parameter can be one of the following values:
 999:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            @arg OB_WRP: A value between OB_WRP_Sector0 and OB_WRP_Sector11                     
1000:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            @arg OB_WRP_Sector_All
1001:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @param  Newstate: new state of the Write Protection.
1002:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *          This parameter can be: ENABLE or DISABLE.
1003:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @retval None  
1004:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   */
1005:Lib/StdPeriphs/src/stm32f4xx_flash.c **** void FLASH_OB_WRPConfig(uint32_t OB_WRP, FunctionalState NewState)
1006:Lib/StdPeriphs/src/stm32f4xx_flash.c **** { 
1007:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
1008:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   
1009:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   /* Check the parameters */
1010:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   assert_param(IS_OB_WRP(OB_WRP));
1011:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   assert_param(IS_FUNCTIONAL_STATE(NewState));
1012:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     
1013:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   status = FLASH_WaitForLastOperation();
1014:Lib/StdPeriphs/src/stm32f4xx_flash.c **** 
1015:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   if(status == FLASH_COMPLETE)
1016:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   { 
1017:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     if(NewState != DISABLE)
1018:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     {
1019:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       *(__IO uint16_t*)OPTCR_BYTE2_ADDRESS &= (~OB_WRP);
1020:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     }
1021:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     else
1022:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     {
1023:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       *(__IO uint16_t*)OPTCR_BYTE2_ADDRESS |= (uint16_t)OB_WRP;
1024:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     }
1025:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   }
1026:Lib/StdPeriphs/src/stm32f4xx_flash.c **** }
