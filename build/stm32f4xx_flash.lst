 429:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @brief  Erases a specified FLASH Sector.
 430:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 431:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @note   If an erase and a program operations are requested simultaneously,    
 432:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         the erase operation is performed before the program one.
 433:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 434:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @param  FLASH_Sector: The Sector number to be erased.
 435:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 436:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *  @note  For STM32F405xx/407xx and STM32F415xx/417xx devices this parameter can 
 437:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         be a value between FLASH_Sector_0 and FLASH_Sector_11.
 438:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 439:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         For STM32F42xxx/43xxx devices this parameter can be a value between 
 440:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         FLASH_Sector_0 and FLASH_Sector_23.
 441:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 442:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         For STM32F401xx devices this parameter can be a value between 
 443:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         FLASH_Sector_0 and FLASH_Sector_5.
 444:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 445:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         For STM32F411xE and STM32F412xG devices this parameter can be a value between 
 446:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         FLASH_Sector_0 and FLASH_Sector_7.
 447:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 448:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         For STM32F410xx devices this parameter can be a value between 
 449:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         FLASH_Sector_0 and FLASH_Sector_4.
 450:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 451:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         For STM32F413_423xx devices this parameter can be a value between 
 452:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         FLASH_Sector_0 and FLASH_Sector_15.
 453:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 454:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @param  VoltageRange: The device voltage range which defines the erase parallelism.  
 455:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *          This parameter can be one of the following values:
 456:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            @arg VoltageRange_1: when the device voltage range is 1.8V to 2.1V, 
 457:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *                                  the operation will be done by byte (8-bit) 
 458:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            @arg VoltageRange_2: when the device voltage range is 2.1V to 2.7V,
 459:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *                                  the operation will be done by half word (16-bit)
 460:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            @arg VoltageRange_3: when the device voltage range is 2.7V to 3.6V,
 461:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *                                  the operation will be done by word (32-bit)
 462:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            @arg VoltageRange_4: when the device voltage range is 2.7V to 3.6V + External Vpp, 
 463:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *                                  the operation will be done by double word (64-bit)
 464:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *       
 465:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_BUSY, FLASH_ERROR_PROGRAM,
 466:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *                       FLASH_ERROR_WRP, FLASH_ERROR_OPERATION or FLASH_COMPLETE.
 467:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   */
 468:Lib/StdPeriphs/src/stm32f4xx_flash.c **** FLASH_Status FLASH_EraseSector(uint32_t FLASH_Sector, uint8_t VoltageRange)
 469:Lib/StdPeriphs/src/stm32f4xx_flash.c **** {
 470:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   uint32_t tmp_psize = 0x0;
 471:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
 472:Lib/StdPeriphs/src/stm32f4xx_flash.c **** 
 473:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   /* Check the parameters */
 474:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   assert_param(IS_FLASH_SECTOR(FLASH_Sector));
 475:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   assert_param(IS_VOLTAGERANGE(VoltageRange));
 476:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   
 477:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   if(VoltageRange == VoltageRange_1)
 478:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   {
 479:Lib/StdPeriphs/src/stm32f4xx_flash.c ****      tmp_psize = FLASH_PSIZE_BYTE;
 480:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   }
 481:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   else if(VoltageRange == VoltageRange_2)
 482:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   {
 483:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     tmp_psize = FLASH_PSIZE_HALF_WORD;
 484:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   }
 485:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   else if(VoltageRange == VoltageRange_3)
ARM GAS  /tmp/ccGoYJQC.s 			page 15


 486:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   {
 487:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     tmp_psize = FLASH_PSIZE_WORD;
 488:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   }
 489:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   else
 490:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   {
 491:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     tmp_psize = FLASH_PSIZE_DOUBLE_WORD;
 492:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   }
 493:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   /* Wait for last operation to be completed */
 494:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   status = FLASH_WaitForLastOperation();
 495:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   
 496:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   if(status == FLASH_COMPLETE)
 497:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   { 
 498:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     /* if the previous operation is completed, proceed to erase the sector */
 499:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     FLASH->CR &= CR_PSIZE_MASK;
 500:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     FLASH->CR |= tmp_psize;
 501:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     FLASH->CR &= SECTOR_MASK;
 502:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     FLASH->CR |= FLASH_CR_SER | FLASH_Sector;
 503:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     FLASH->CR |= FLASH_CR_STRT;
 504:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     
 505:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     /* Wait for last operation to be completed */
 506:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     status = FLASH_WaitForLastOperation();
 507:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     
 508:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     /* if the erase operation is completed, disable the SER Bit */
 509:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     FLASH->CR &= (~FLASH_CR_SER);
 510:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     FLASH->CR &= SECTOR_MASK; 
 511:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   }
 512:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   /* Return the Erase Status */
 513:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   return status;
 514:Lib/StdPeriphs/src/stm32f4xx_flash.c **** }
 515:Lib/StdPeriphs/src/stm32f4xx_flash.c **** 
 516:Lib/StdPeriphs/src/stm32f4xx_flash.c **** /**
 517:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @brief  Erases all FLASH Sectors.
 518:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *
 519:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @note   If an erase and a program operations are requested simultaneously,    
 520:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *         the erase operation is performed before the program one.
 521:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *  
 522:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @param  VoltageRange: The device voltage range which defines the erase parallelism.  
 523:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *          This parameter can be one of the following values:
 524:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            @arg VoltageRange_1: when the device voltage range is 1.8V to 2.1V, 
 525:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *                                  the operation will be done by byte (8-bit) 
 526:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *            @arg VoltageRange_2: when the device voltage range is 2.1V to 2.7V,
 527:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   *                                  the operation will be done by half word (16-bit)
