 207:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       -@- On STM32F405xx/407xx and STM32F415xx/417xx devices: 
 208:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS = '0' Scale 2 mode, the maximum value of fHCLK = 144MHz. 
 209:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS = '1' Scale 1 mode, the maximum value of fHCLK = 168MHz. 
 210:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           [..] 
 211:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           On STM32F42xxx/43xxx devices:
 212:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS[1:0] = '0x01' Scale 3 mode, the maximum value of fHCLK is 120MHz.
 213:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS[1:0] = '0x10' Scale 2 mode, the maximum value of fHCLK is 144MHz if OverDr
 214:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS[1:0] = '0x11' Scale 1 mode, the maximum value of fHCLK is 168MHz if OverDr
 215:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           [..]
 216:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           On STM32F401x devices:
 217:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS[1:0] = '0x01' Scale 3 mode, the maximum value of fHCLK is 60MHz.
 218:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS[1:0] = '0x10' Scale 2 mode, the maximum value of fHCLK is 84MHz.
 219:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           [..]  
 220:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           On STM32F410xx/STM32F411xE devices:
 221:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS[1:0] = '0x01' Scale 3 mode, the maximum value of fHCLK is 64MHz.
 222:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS[1:0] = '0x10' Scale 2 mode, the maximum value of fHCLK is 84MHz.
 223:Lib/StdPeriphs/src/stm32f4xx_flash.c ****            (++) when VOS[1:0] = '0x11' Scale 1 mode, the maximum value of fHCLK is 100MHz.
