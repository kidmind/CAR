 929:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (+) uint8_t FLASH_OB_GetBOR(void)
 930:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     [..]  
 931:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       The following function can be used only for STM32F42xxx/43xxx devices. 
 932:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (+) void FLASH_OB_BootConfig(uint8_t OB_BOOT)
 933:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     [..]   
 934:Lib/StdPeriphs/src/stm32f4xx_flash.c ****      Any operation of erase or program should follow these steps:
 935:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (#) Call the FLASH_OB_Unlock() function to enable the FLASH option control 
 936:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           register access
 937:Lib/StdPeriphs/src/stm32f4xx_flash.c **** 
 938:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (#) Call one or several functions to program the desired Option Bytes:
 939:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) void FLASH_OB_WRPConfig(uint32_t OB_WRP, FunctionalState NewState) 
 940:Lib/StdPeriphs/src/stm32f4xx_flash.c ****              => to Enable/Disable the desired sector write protection
 941:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) void FLASH_OB_RDPConfig(uint8_t OB_RDP) => to set the desired read 
ARM GAS  /tmp/ccGoYJQC.s 			page 23


 942:Lib/StdPeriphs/src/stm32f4xx_flash.c ****              Protection Level
 943:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) void FLASH_OB_UserConfig(uint8_t OB_IWDG, uint8_t OB_STOP, uint8_t OB_STDBY) 
 944:Lib/StdPeriphs/src/stm32f4xx_flash.c ****              => to configure the user Option Bytes.
 945:Lib/StdPeriphs/src/stm32f4xx_flash.c ****         (++) void FLASH_OB_BORConfig(uint8_t OB_BOR) => to set the BOR Level 			 
 946:Lib/StdPeriphs/src/stm32f4xx_flash.c **** 
 947:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (#) Once all needed Option Bytes to be programmed are correctly written, 
 948:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           call the FLASH_OB_Launch() function to launch the Option Bytes 
 949:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           programming process.
 950:Lib/StdPeriphs/src/stm32f4xx_flash.c ****      
 951:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       -@- When changing the IWDG mode from HW to SW or from SW to HW, a system 
 952:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           reset is needed to make the change effective.  
 953:Lib/StdPeriphs/src/stm32f4xx_flash.c **** 
 954:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (#) Call the FLASH_OB_Lock() function to disable the FLASH option control 
 955:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           register access (recommended to protect the Option Bytes against 
 956:Lib/StdPeriphs/src/stm32f4xx_flash.c ****           possible unwanted operations)
 957:Lib/StdPeriphs/src/stm32f4xx_flash.c ****     
 958:Lib/StdPeriphs/src/stm32f4xx_flash.c **** @endverbatim
 959:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   * @{
 960:Lib/StdPeriphs/src/stm32f4xx_flash.c ****   */
