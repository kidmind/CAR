 919:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (+) void FLASH_OB_UserConfig(uint8_t OB_IWDG, uint8_t OB_STOP, uint8_t OB_STDBY)
 920:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (+) void FLASH_OB_BORConfig(uint8_t OB_BOR)
 921:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (+) FLASH_Status FLASH_ProgramOTP(uint32_t Address, uint32_t Data)
 922:Lib/StdPeriphs/src/stm32f4xx_flash.c ****       (+) FLASH_Status FLASH_OB_Launch(void)
