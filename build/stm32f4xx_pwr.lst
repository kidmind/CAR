 787:Lib/StdPeriphs/src/stm32f4xx_pwr.c **** /**
 788:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   * @brief  Enters STOP mode.
 789:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *   
 790:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   * @note   In Stop mode, all I/O pins keep the same state as in Run mode.
 791:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   * @note   When exiting Stop mode by issuing an interrupt or a wakeup event, 
 792:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *         the HSI RC oscillator is selected as system clock.
 793:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   * @note   When the voltage regulator operates in low power mode, an additional 
 794:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *         startup delay is incurred when waking up from Stop mode. 
 795:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *         By keeping the internal regulator ON during Stop mode, the consumption 
 796:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *         is higher although the startup time is reduced.
 797:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *     
 798:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   * @param  PWR_Regulator: specifies the regulator state in STOP mode.
 799:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *          This parameter can be one of the following values:
 800:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *            @arg PWR_MainRegulator_ON: STOP mode with regulator ON
 801:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *            @arg PWR_LowPowerRegulator_ON: STOP mode with low power regulator ON
 802:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   * @param  PWR_STOPEntry: specifies if STOP mode in entered with WFI or WFE instruction.
 803:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *          This parameter can be one of the following values:
 804:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *            @arg PWR_STOPEntry_WFI: enter STOP mode with WFI instruction
 805:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *            @arg PWR_STOPEntry_WFE: enter STOP mode with WFE instruction
 806:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   * @retval None
 807:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   */
 808:Lib/StdPeriphs/src/stm32f4xx_pwr.c **** void PWR_EnterSTOPMode(uint32_t PWR_Regulator, uint8_t PWR_STOPEntry)
