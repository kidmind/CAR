  86:CMSIS/core_cmInstr.h **** /** \brief  Instruction Synchronization Barrier
  87:CMSIS/core_cmInstr.h **** 
  88:CMSIS/core_cmInstr.h ****     Instruction Synchronization Barrier flushes the pipeline in the processor,
  89:CMSIS/core_cmInstr.h ****     so that all instructions following the ISB are fetched from cache or
  90:CMSIS/core_cmInstr.h ****     memory, after the instruction has been completed.
  91:CMSIS/core_cmInstr.h ****  */
  92:CMSIS/core_cmInstr.h **** #define __ISB() do {\
  93:CMSIS/core_cmInstr.h ****                    __schedule_barrier();\
  94:CMSIS/core_cmInstr.h ****                    __isb(0xF);\
  95:CMSIS/core_cmInstr.h ****                    __schedule_barrier();\
  96:CMSIS/core_cmInstr.h ****                 } while (0)
  97:CMSIS/core_cmInstr.h **** 
  98:CMSIS/core_cmInstr.h **** /** \brief  Data Synchronization Barrier
  99:CMSIS/core_cmInstr.h **** 
 100:CMSIS/core_cmInstr.h ****     This function acts as a special kind of Data Memory Barrier.
 101:CMSIS/core_cmInstr.h ****     It completes when all explicit memory accesses before this instruction complete.
 102:CMSIS/core_cmInstr.h ****  */
 103:CMSIS/core_cmInstr.h **** #define __DSB() do {\
 104:CMSIS/core_cmInstr.h ****                    __schedule_barrier();\
 105:CMSIS/core_cmInstr.h ****                    __dsb(0xF);\
 106:CMSIS/core_cmInstr.h ****                    __schedule_barrier();\
 107:CMSIS/core_cmInstr.h ****                 } while (0)
 108:CMSIS/core_cmInstr.h **** 
 109:CMSIS/core_cmInstr.h **** /** \brief  Data Memory Barrier
 110:CMSIS/core_cmInstr.h **** 
 111:CMSIS/core_cmInstr.h ****     This function ensures the apparent order of the explicit memory operations before
 112:CMSIS/core_cmInstr.h ****     and after the instruction, without ensuring their completion.
 113:CMSIS/core_cmInstr.h ****  */
 114:CMSIS/core_cmInstr.h **** #define __DMB() do {\
 115:CMSIS/core_cmInstr.h ****                    __schedule_barrier();\
ARM GAS  C:\Users\asus\AppData\Local\Temp\ccK7S6kH.s 			page 25


 116:CMSIS/core_cmInstr.h ****                    __dmb(0xF);\
 117:CMSIS/core_cmInstr.h ****                    __schedule_barrier();\
 118:CMSIS/core_cmInstr.h ****                 } while (0)
 119:CMSIS/core_cmInstr.h **** 
 120:CMSIS/core_cmInstr.h **** /** \brief  Reverse byte order (32 bit)
