 639:Lib/StdPeriphs/src/stm32f4xx_pwr.c **** /** @defgroup PWR_Group5 FLASH Power Down configuration functions
 640:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *  @brief   FLASH Power Down configuration functions 
 641:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   *
 642:Lib/StdPeriphs/src/stm32f4xx_pwr.c **** @verbatim   
 643:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****  ===============================================================================
 644:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****              ##### FLASH Power Down configuration functions #####
 645:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****  ===============================================================================  
 646:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****     [..]
 647:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****       (+) By setting the FPDS bit in the PWR_CR register by using the 
 648:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****           PWR_FlashPowerDownCmd() function, the Flash memory also enters power 
 649:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****           down mode when the device enters Stop mode. When the Flash memory 
 650:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****           is in power down mode, an additional startup delay is incurred when 
 651:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****           waking up from Stop mode.
 652:Lib/StdPeriphs/src/stm32f4xx_pwr.c **** @endverbatim
 653:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   * @{
 654:Lib/StdPeriphs/src/stm32f4xx_pwr.c ****   */
 655:Lib/StdPeriphs/src/stm32f4xx_pwr.c **** 
 656:Lib/StdPeriphs/src/stm32f4xx_pwr.c **** /**
