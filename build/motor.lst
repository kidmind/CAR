  68:MyHardWare/Src/motor.c ****     break;
  69:MyHardWare/Src/motor.c ****   case MOTOR_LEFT:
  70:MyHardWare/Src/motor.c ****     inst = &Motor_Left;
  71:MyHardWare/Src/motor.c ****     break;
  72:MyHardWare/Src/motor.c ****   default:
