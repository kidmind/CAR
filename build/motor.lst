  45:MyHardWare/Src/motor.c ****   Motor_Class_t *inst = NULL;
  46:MyHardWare/Src/motor.c **** 
  47:MyHardWare/Src/motor.c **** #ifdef QUAD_MOTOR_DRIVE
  48:MyHardWare/Src/motor.c ****   switch (motor) {
  49:MyHardWare/Src/motor.c ****   case MOTOR_FR:
  50:MyHardWare/Src/motor.c ****     inst = &Motor_FR;
  51:MyHardWare/Src/motor.c ****     break;
  52:MyHardWare/Src/motor.c ****   case MOTOR_FL:
  53:MyHardWare/Src/motor.c ****     inst = &Motor_FL;
  54:MyHardWare/Src/motor.c ****     break;
  55:MyHardWare/Src/motor.c ****   case MOTOR_BR:
  56:MyHardWare/Src/motor.c ****     inst = &Motor_BR;
  57:MyHardWare/Src/motor.c ****     break;
  58:MyHardWare/Src/motor.c ****   case MOTOR_BL:
  59:MyHardWare/Src/motor.c ****     inst = &Motor_BL;
  60:MyHardWare/Src/motor.c ****     break;
  61:MyHardWare/Src/motor.c ****   default:
  62:MyHardWare/Src/motor.c ****     return;
  63:MyHardWare/Src/motor.c ****   }
  64:MyHardWare/Src/motor.c **** #else
