  79:MyHardWare/Src/motor.c ****     speed = MOTOR_PWM_MAX_DUTY;
  80:MyHardWare/Src/motor.c ****   } else if (speed < -MOTOR_PWM_MAX_DUTY) {
  81:MyHardWare/Src/motor.c ****     speed = -MOTOR_PWM_MAX_DUTY;
