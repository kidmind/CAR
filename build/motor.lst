 264:MyHardWare/Src/motor.c **** /**
 265:MyHardWare/Src/motor.c ****  * @brief 设置电机速度（带符号）
 266:MyHardWare/Src/motor.c ****  * @param motor 电机ID
 267:MyHardWare/Src/motor.c ****  * @param speed 速度值 (-MOTOR_PWM_MAX_DUTY ~ +MOTOR_PWM_MAX_DUTY)
 268:MyHardWare/Src/motor.c ****  */
 269:MyHardWare/Src/motor.c **** void Motor_SetSpeed(Motor_Id_e motor, int16_t speed)
 270:MyHardWare/Src/motor.c **** {
 271:MyHardWare/Src/motor.c ****     // 限制速度范围
 272:MyHardWare/Src/motor.c ****     if (speed > MOTOR_PWM_MAX_DUTY) {
 273:MyHardWare/Src/motor.c ****         speed = MOTOR_PWM_MAX_DUTY;
 274:MyHardWare/Src/motor.c ****     } else if (speed < -MOTOR_PWM_MAX_DUTY) {
 275:MyHardWare/Src/motor.c ****         speed = -MOTOR_PWM_MAX_DUTY;
 276:MyHardWare/Src/motor.c ****     }
 277:MyHardWare/Src/motor.c **** 
 278:MyHardWare/Src/motor.c ****     // 根据速度正负设置方向和占空比
 279:MyHardWare/Src/motor.c ****     if (speed > 0) {
 280:MyHardWare/Src/motor.c ****         Motor_SetDirection(motor, MOTOR_DIR_FORWARD);
 281:MyHardWare/Src/motor.c ****         Motor_SetDuty(motor, (uint16_t)speed);
 282:MyHardWare/Src/motor.c ****     } else if (speed < 0) {
 283:MyHardWare/Src/motor.c ****         Motor_SetDirection(motor, MOTOR_DIR_BACKWARD);
 284:MyHardWare/Src/motor.c ****         Motor_SetDuty(motor, (uint16_t)(-speed));
 285:MyHardWare/Src/motor.c ****     } else {
 286:MyHardWare/Src/motor.c ****         Motor_Stop(motor);
 287:MyHardWare/Src/motor.c ****     }
 288:MyHardWare/Src/motor.c **** }
