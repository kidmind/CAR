 257:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** /**
 258:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @brief  Configures the External High Speed oscillator (HSE).
 259:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   After enabling the HSE (RCC_HSE_ON or RCC_HSE_Bypass), the application
 260:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         software should wait on HSERDY flag to be set indicating that HSE clock
 261:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         is stable and can be used to clock the PLL and/or system clock.
 262:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   HSE state can not be changed if it is used directly or through the
 263:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         PLL as system clock. In this case, you have to select another source
 264:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         of the system clock then change the HSE state (ex. disable it).
 265:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   The HSE is stopped by hardware when entering STOP and STANDBY modes.  
 266:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   This function reset the CSSON bit, so if the Clock security system(CSS)
 267:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         was previously enabled you have to enable it again after calling this
 268:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         function.    
 269:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @param  RCC_HSE: specifies the new state of the HSE.
 270:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          This parameter can be one of the following values:
 271:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *            @arg RCC_HSE_OFF: turn OFF the HSE oscillator, HSERDY flag goes low after
 272:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *                              6 HSE oscillator clock cycles.
 273:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *            @arg RCC_HSE_ON: turn ON the HSE oscillator
 274:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *            @arg RCC_HSE_Bypass: HSE oscillator bypassed with external clock
 275:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @retval None
 276:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   */
