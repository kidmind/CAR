 861:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** /**
 862:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @brief  Enables or disables the Clock Security System.
 863:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   If a failure is detected on the HSE oscillator clock, this oscillator
 864:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         is automatically disabled and an interrupt is generated to inform the
 865:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         software about the failure (Clock Security System Interrupt, CSSI),
 866:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         allowing the MCU to perform rescue operations. The CSSI is linked to 
 867:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         the Cortex-M4 NMI (Non-Maskable Interrupt) exception vector.  
 868:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @param  NewState: new state of the Clock Security System.
 869:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         This parameter can be: ENABLE or DISABLE.
 870:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @retval None
 871:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   */
