   1:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** /**
   2:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   ******************************************************************************
   3:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @file    stm32f4xx_rcc.c
   4:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @author  MCD Application Team
   5:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @version V1.8.1
   6:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @date    27-January-2022
   7:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @brief   This file provides firmware functions to manage the following 
   8:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          functionalities of the Reset and clock control (RCC) peripheral:
   9:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *           + Internal/external clocks, PLL, CSS and MCO configuration
  10:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *           + System, AHB and APB busses clocks configuration
  11:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *           + Peripheral clocks configuration
  12:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *           + Interrupts and flags management
  13:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *
  14:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****  @verbatim
  15:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****  ===============================================================================
  16:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****                       ##### RCC specific features #####
  17:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****  ===============================================================================
  18:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****     [..]  
  19:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       After reset the device is running from Internal High Speed oscillator 
  20:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (HSI 16MHz) with Flash 0 wait state, Flash prefetch buffer, D-Cache 
  21:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       and I-Cache are disabled, and all peripherals are off except internal
  22:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       SRAM, Flash and JTAG.
  23:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (+) There is no prescaler on High speed (AHB) and Low speed (APB) busses;
  24:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           all peripherals mapped on these busses are running at HSI speed.
  25:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (+) The clock for all peripherals is switched off, except the SRAM and FLASH.
  26:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (+) All GPIOs are in input floating state, except the JTAG pins which
  27:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           are assigned to be used for debug purpose.
  28:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****     [..]          
  29:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       Once the device started from reset, the user application has to:
  30:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (+) Configure the clock source to be used to drive the System clock
ARM GAS  C:\Users\asus\AppData\Local\Temp\ccEdY3aN.s 			page 2


  31:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           (if the application needs higher frequency/performance)
  32:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (+) Configure the System clock frequency and Flash settings  
  33:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (+) Configure the AHB and APB busses prescalers
  34:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (+) Enable the clock for the peripheral(s) to be used
  35:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (+) Configure the clock source(s) for peripherals which clocks are not
  36:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           derived from the System clock (I2S, RTC, ADC, USB OTG FS/SDIO/RNG)
  37:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****  @endverbatim    
