 289:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** /**
 290:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @brief  Waits for HSE start-up.
 291:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   This functions waits on HSERDY flag to be set and return SUCCESS if 
 292:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         this flag is set, otherwise returns ERROR if the timeout is reached 
 293:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         and this flag is not set. The timeout value is defined by the constant
 294:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         HSE_STARTUP_TIMEOUT in stm32f4xx.h file. You can tailor it depending
 295:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         on the HSE crystal used in your application. 
 296:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @param  None
 297:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @retval An ErrorStatus enumeration value:
 298:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          - SUCCESS: HSE oscillator is stable and ready to use
 299:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          - ERROR: HSE oscillator not yet ready
 300:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   */
 301:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** ErrorStatus RCC_WaitForHSEStartUp(void)
 302:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** {
 303:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   __IO uint32_t startupcounter = 0;
 304:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   ErrorStatus status = ERROR;
 305:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   FlagStatus hsestatus = RESET;
 306:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   /* Wait till HSE is ready and if Time out is reached exit */
 307:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   do
 308:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   {
 309:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****     hsestatus = RCC_GetFlagStatus(RCC_FLAG_HSERDY);
 310:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****     startupcounter++;
 311:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   } while((startupcounter != HSE_STARTUP_TIMEOUT) && (hsestatus == RESET));
 312:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** 
 313:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   if (RCC_GetFlagStatus(RCC_FLAG_HSERDY) != RESET)
 314:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   {
 315:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****     status = SUCCESS;
 316:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   }
 317:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   else
 318:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   {
 319:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****     status = ERROR;
 320:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   }
 321:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   return (status);
 322:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** }
 323:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** 
 324:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** /**
