 442:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** /**
 443:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @brief  Configures the main PLL clock source, multiplication and division factors.
 444:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   This function must be used only when the main PLL is disabled.
 445:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *  
 446:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @param  RCC_PLLSource: specifies the PLL entry clock source.
 447:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          This parameter can be one of the following values:
 448:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *            @arg RCC_PLLSource_HSI: HSI oscillator clock selected as PLL clock entry
 449:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *            @arg RCC_PLLSource_HSE: HSE oscillator clock selected as PLL clock entry
 450:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   This clock source (RCC_PLLSource) is common for the main PLL and PLLI2S.  
 451:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *  
 452:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @param  PLLM: specifies the division factor for PLL VCO input clock
 453:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          This parameter must be a number between 0 and 63.
 454:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   You have to set the PLLM parameter correctly to ensure that the VCO input
 455:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         frequency ranges from 1 to 2 MHz. It is recommended to select a frequency
 456:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         of 2 MHz to limit PLL jitter.
 457:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *  
 458:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @param  PLLN: specifies the multiplication factor for PLL VCO output clock
 459:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          This parameter must be a number between 50 and 432.
 460:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   You have to set the PLLN parameter correctly to ensure that the VCO
 461:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         output frequency is between 100 and 432 MHz.
 462:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *   
 463:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @param  PLLP: specifies the division factor for main system clock (SYSCLK)
 464:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          This parameter must be a number in the range {2, 4, 6, or 8}.
 465:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   You have to set the PLLP parameter correctly to not exceed 168 MHz on
 466:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         the System clock frequency.
 467:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *  
 468:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @param  PLLQ: specifies the division factor for OTG FS, SDIO and RNG clocks
 469:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          This parameter must be a number between 4 and 15.
 470:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *
 471:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @param  PLLR: specifies the division factor for I2S, SAI, SYSTEM, SPDIF in STM32F446xx devices
ARM GAS  C:\Users\asus\AppData\Local\Temp\ccEdY3aN.s 			page 14


 472:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *          This parameter must be a number between 2 and 7.
 473:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *
 474:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @note   If the USB OTG FS is used in your application, you have to set the
 475:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         PLLQ parameter correctly to have 48 MHz clock for the USB. However,
 476:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         the SDIO and RNG need a frequency lower than or equal to 48 MHz to work
 477:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *         correctly.
 478:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   *   
 479:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @retval None
 480:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   */
 481:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** void RCC_PLLConfig(uint32_t RCC_PLLSource, uint32_t PLLM, uint32_t PLLN, uint32_t PLLP, uint32_t PL
 482:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** {
 483:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   /* Check the parameters */
 484:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   assert_param(IS_RCC_PLL_SOURCE(RCC_PLLSource));
 485:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   assert_param(IS_RCC_PLLM_VALUE(PLLM));
 486:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   assert_param(IS_RCC_PLLN_VALUE(PLLN));
 487:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   assert_param(IS_RCC_PLLP_VALUE(PLLP));
 488:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   assert_param(IS_RCC_PLLQ_VALUE(PLLQ));
 489:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   assert_param(IS_RCC_PLLR_VALUE(PLLR));
 490:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   
 491:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   RCC->PLLCFGR = PLLM | (PLLN << 6) | (((PLLP >> 1) -1) << 16) | (RCC_PLLSource) |
 492:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****                  (PLLQ << 24) | (PLLR << 28);
 493:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** }
