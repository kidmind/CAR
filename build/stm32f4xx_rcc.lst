1540:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   /* Check the parameters */
1541:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   assert_param(IS_RCC_I2SCLK_SOURCE(RCC_I2SCLKSource));
1542:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   assert_param(IS_RCC_I2S_APBx(RCC_I2SAPBx));
