1407:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** /** @defgroup RCC_Group3 Peripheral clocks configuration functions
1408:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****  *  @brief   Peripheral clocks configuration functions 
1409:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****  *
1410:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** @verbatim   
1411:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****  ===============================================================================
1412:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****               ##### Peripheral clocks configuration functions #####
1413:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****  ===============================================================================  
1414:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****     [..] This section provide functions allowing to configure the Peripheral clocks. 
1415:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   
1416:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (#) The RTC clock which is derived from the LSI, LSE or HSE clock divided 
1417:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           by 2 to 31.
1418:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****      
1419:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (#) After restart from Reset or wakeup from STANDBY, all peripherals are off
1420:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           except internal SRAM, Flash and JTAG. Before to start using a peripheral 
1421:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           you have to enable its interface clock. You can do this using 
1422:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           RCC_AHBPeriphClockCmd(), RCC_APB2PeriphClockCmd() and RCC_APB1PeriphClockCmd() functions.
1423:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** 
1424:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (#) To reset the peripherals configuration (to the default state after device reset)
1425:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           you can use RCC_AHBPeriphResetCmd(), RCC_APB2PeriphResetCmd() and 
1426:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           RCC_APB1PeriphResetCmd() functions.
1427:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****      
1428:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****       (#) To further reduce power consumption in SLEEP mode the peripheral clocks 
ARM GAS  C:\Users\asus\AppData\Local\Temp\ccEdY3aN.s 			page 44


1429:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           can be disabled prior to executing the WFI or WFE instructions. 
1430:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           You can do this using RCC_AHBPeriphClockLPModeCmd(), 
1431:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****           RCC_APB2PeriphClockLPModeCmd() and RCC_APB1PeriphClockLPModeCmd() functions.  
1432:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** 
1433:Lib/StdPeriphs/src/stm32f4xx_rcc.c **** @endverbatim
1434:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   * @{
1435:Lib/StdPeriphs/src/stm32f4xx_rcc.c ****   */
